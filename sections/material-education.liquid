<section class="material-section">
  <div class="material-inner">

    <div class="material-header reveal">
      <span class="section-label">The Stone</span>
      <h2 class="section-title">Why <em>Amethyst?</em></h2>
    </div>

    <div class="material-grid">

      <div class="material-card material-card--hero reveal">
        <div class="material-card-icon">
          <svg aria-hidden="true" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <h3 class="material-card-title">Not All Stones Are Equal</h3>
        <p class="material-card-text">Most gua sha tools sold online use cheap Xiuyan jade or dyed glass. Our tools are carved from genuine amethyst — a harder crystal (7 Mohs) that polishes smoother, feels naturally cool against skin, and glides without dragging.</p>
      </div>

      <div class="material-card reveal reveal-delay-1">
        <div class="material-card-num">01</div>
        <h4 class="material-card-subtitle">Feels Cool on Skin</h4>
        <p class="material-card-text">Natural crystal that feels cool to the touch — a soothing start to your morning ritual.</p>
      </div>

      <div class="material-card reveal reveal-delay-2">
        <div class="material-card-num">02</div>
        <h4 class="material-card-subtitle">Smoother Polish</h4>
        <p class="material-card-text">Harder than jade on the Mohs scale, so it polishes to a smoother finish. Less friction on skin, better glide with oil, and no micro-scratches that cheaper stones can leave.</p>
      </div>

      <div class="material-card reveal reveal-delay-3">
        <div class="material-card-num">03</div>
        <h4 class="material-card-subtitle">Each Stone Is Unique</h4>
        <p class="material-card-text">Every BY RITUEL gua sha has its own natural pattern. No two are alike — your stone is yours alone. Natural colour variations are a sign of authenticity.</p>
      </div>

    </div>

    <div class="material-comparison reveal">
      <div class="material-compare-row material-compare-header">
        <span></span>
        <span class="compare-brand">BY RITUEL Amethyst</span>
        <span class="compare-generic">Generic Gua Sha</span>
      </div>
      <div class="material-compare-row">
        <span class="compare-feature">Material</span>
        <span class="compare-good">Genuine amethyst crystal</span>
        <span class="compare-bad">Xiuyan jade or dyed glass</span>
      </div>
      <div class="material-compare-row">
        <span class="compare-feature">Hardness</span>
        <span class="compare-good">7 Mohs — scratch-resistant</span>
        <span class="compare-bad">Varies — often soft or brittle</span>
      </div>
      <div class="material-compare-row">
        <span class="compare-feature">Surface polish</span>
        <span class="compare-good">Ultra-smooth finish</span>
        <span class="compare-bad">Rough, uneven edges</span>
      </div>
      <div class="material-compare-row">
        <span class="compare-feature">Edge design</span>
        <span class="compare-good">Concave jawline edge</span>
        <span class="compare-bad">Generic flat shape</span>
      </div>
      <div class="material-compare-row">
        <span class="compare-feature">Includes guide</span>
        <span class="compare-good">Step-by-step ritual guide</span>
        <span class="compare-bad">No instructions</span>
      </div>
    </div>

  </div>
</section>

<style>
.material-section {
  padding: 100px 80px;
  background: var(--espresso, #1E120A);
}
.material-inner {
  max-width: 1200px;
  margin: 0 auto;
}
.material-header {
  text-align: center;
  margin-bottom: 64px;
}
.material-header .section-label {
  color: var(--terracotta, #B8704A);
}
.material-header .section-title {
  color: var(--cream, #F7F2EA);
}
.material-header .section-title em {
  color: var(--blush, #E8C5B0);
}
.material-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 2px;
  margin-bottom: 64px;
}
.material-card {
  padding: 40px 32px;
  background: rgba(255,255,255,0.04);
  transition: background 0.35s;
}
.material-card:hover {
  background: rgba(255,255,255,0.07);
}
.material-card--hero {
  grid-column: 1 / 2;
}
.material-card-icon {
  color: var(--terracotta, #B8704A);
  margin-bottom: 24px;
}
.material-card-num {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: 42px;
  font-weight: 300;
  color: rgba(247,242,234,0.12);
  line-height: 1;
  margin-bottom: 20px;
}
.material-card-title {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: 22px;
  font-weight: 400;
  color: var(--cream, #F7F2EA);
  margin-bottom: 16px;
  line-height: 1.3;
}
.material-card-subtitle {
  font-family: var(--sans, 'Jost', sans-serif);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--blush, #E8C5B0);
  margin-bottom: 12px;
}
.material-card-text {
  font-size: 14px;
  color: rgba(247,242,234,0.5);
  line-height: 1.75;
}

/* Comparison Table */
.material-comparison {
  max-width: 800px;
  margin: 0 auto;
}
.material-compare-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0;
  border-bottom: 1px solid rgba(247,242,234,0.06);
}
.material-compare-header {
  border-bottom: 1px solid rgba(247,242,234,0.12);
  padding-bottom: 12px;
  margin-bottom: 4px;
}
.compare-brand {
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--terracotta, #B8704A);
  font-weight: 500;
  padding: 12px 16px;
}
.compare-generic {
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(247,242,234,0.25);
  padding: 12px 16px;
}
.compare-feature {
  font-size: 13px;
  font-weight: 500;
  color: var(--cream, #F7F2EA);
  padding: 14px 16px;
}
.compare-good {
  font-size: 13px;
  color: rgba(247,242,234,0.65);
  padding: 14px 16px;
}
.compare-bad {
  font-size: 13px;
  color: rgba(247,242,234,0.25);
  padding: 14px 16px;
  font-style: italic;
}

@media (max-width: 900px) {
  .material-section { padding: 64px 24px; }
  .material-grid { grid-template-columns: 1fr; }
  .material-card--hero { grid-column: auto; }
  .material-compare-row { grid-template-columns: 1fr; gap: 4px; padding: 12px 0; }
  .material-compare-header { display: none; }
  .compare-feature { font-weight: 600; padding: 8px 16px 4px; }
  .compare-good, .compare-bad { padding: 2px 16px 8px; }
  .compare-good::before { content: 'BY RITUEL: '; font-weight: 500; color: var(--terracotta); }
  .compare-bad::before { content: 'Generic: '; font-weight: 500; color: rgba(247,242,234,0.25); }
}
</style>

{% schema %}
{
  "name": "Material Education",
  "presets": [{ "name": "Material Education" }]
}
{% endschema %}
