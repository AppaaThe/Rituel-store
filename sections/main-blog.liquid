<div class="blog-page">
  <div class="blog-hero">
    <img class="blog-hero-bg" src="{{ 'br-hero-blog.webp' | asset_url }}" alt="" loading="eager">
    <div class="blog-hero-content">
      <p class="blog-eyebrow">The Ritual Guide</p>
      <h1>{{ blog.title }}</h1>
      <p class="blog-subtitle">Education, technique, and the science behind the ritual.</p>
    </div>
  </div>

  {%- assign fallback_imgs = 'br-blog-jawline.webp,br-blog-science.webp,br-blog-routine.webp,br-blog-beginners.webp' | split: ',' -%}

  <div class="blog-grid">
    {% for article in blog.articles %}
      {%- assign custom_img = '' -%}
      {%- assign handle = article.handle | downcase -%}
      {%- if article.image -%}
        {%- assign custom_img = article.image | image_url: width: 1000 -%}
      {%- elsif handle contains 'jawline' or handle contains 'nasolabial' or handle contains 'tmj' -%}
        {%- assign custom_img = 'br-blog-jawline.webp' | asset_url -%}
      {%- elsif handle contains 'science' or handle contains 'comedogenic' or handle contains 'amethyst-gua-sha-vs-jade' or handle contains 'rose-quartz' -%}
        {%- assign custom_img = 'br-blog-science.webp' | asset_url -%}
      {%- elsif handle contains 'moisturizer' or handle contains 'sunscreen' or handle contains 'routine' or handle contains 'morning' -%}
        {%- assign custom_img = 'br-blog-routine.webp' | asset_url -%}
      {%- elsif handle contains 'red-marks' or handle contains 'under-eye' or handle contains 'acne' or handle contains 'hangover' or handle contains 'puffiness' or handle contains 'how-often' -%}
        {%- assign custom_img = 'br-blog-beginners.webp' | asset_url -%}
      {%- else -%}
        {%- assign cycle_i = forloop.index0 | modulo: 4 -%}
        {%- assign custom_img = fallback_imgs[cycle_i] | asset_url -%}
      {%- endif -%}

      <a href="{{ article.url }}" class="blog-card">
        <div class="blog-card-img">
          <img src="{{ custom_img }}" alt="{{ article.title | escape }}" loading="lazy" />
        </div>
        <div class="blog-card-body">
          <p class="blog-card-date">{{ article.published_at | date: "%B %d, %Y" }}</p>
          <h2>{{ article.title }}</h2>
          <p class="blog-card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
          <span class="blog-card-cta">Read more →</span>
        </div>
      </a>
    {% endfor %}
  </div>

  {% if paginate.pages > 1 %}
    <div class="blog-pagination">
      {{ paginate | default_pagination }}
    </div>
  {% endif %}
</div>

<style>
  .blog-page {
    min-height: 100vh;
    background: var(--cream, #FAF6F0);
  }

  .blog-hero {
    position: relative;
    background: var(--espresso, #2C1810);
    padding: 140px 40px 120px;
    text-align: center;
    overflow: hidden;
    min-height: 58vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .blog-hero-bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0.42;
    filter: saturate(0.9);
  }
  .blog-hero::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(30,18,10,0.35) 0%, rgba(30,18,10,0.75) 100%);
    pointer-events: none;
  }
  .blog-hero-content { position: relative; z-index: 2; max-width: 800px; }

  .blog-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--terracotta, #B8704A);
    margin-bottom: 20px;
  }

  .blog-hero h1 {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 300;
    color: #FAF6F0;
    margin-bottom: 16px;
    line-height: 1.15;
  }

  .blog-subtitle {
    font-size: 16px;
    color: rgba(250,246,240,0.5);
    letter-spacing: 0.05em;
  }

  .blog-grid {
    max-width: 1100px;
    margin: 0 auto;
    padding: 72px 32px 100px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 40px;
  }

  .blog-card {
    text-decoration: none;
    color: inherit;
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 20px rgba(44,24,16,0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 40px rgba(44,24,16,0.12);
  }

  .blog-card-img {
    width: 100%;
    height: 300px;
    overflow: hidden;
  }

  .blog-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .blog-card:hover .blog-card-img img {
    transform: scale(1.04);
  }

  .blog-card-img--placeholder {
    background: linear-gradient(135deg, var(--terracotta) 0%, #8B6845 100%);
  }

  .blog-card-body {
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog-card-date {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--stone, #8B7355);
    margin-bottom: 12px;
  }

  .blog-card-body h2 {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--espresso, #2C1810);
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .blog-card-excerpt {
    font-size: 14px;
    color: var(--stone, #8B7355);
    line-height: 1.7;
    margin-bottom: 20px;
    flex: 1;
  }

  .blog-card-cta {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta, #B8704A);
  }

  .blog-pagination {
    text-align: center;
    padding: 0 32px 80px;
  }

  @media (max-width: 768px) {
    .blog-grid { grid-template-columns: 1fr; padding: 48px 20px 72px; }
    .blog-hero { padding: 80px 24px 60px; }
  }
</style>

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
