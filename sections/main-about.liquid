}
.about-intro-inner.in-view,
.about-founder-grid.in-view,
.about-quote-inner.in-view,
.about-beliefs-header.in-view,
.about-values.in-view,
.about-craft-grid.in-view,
.about-closing-inner.in-view {
  opacity: 1;
  transform: translateY(0);
}

