<section class="value-strip">
  <div class="value-strip-inner">

    <div class="value-item">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
      </svg>
      <span>Cruelty-Free</span>
    </div>

    <div class="value-sep"></div>

    <div class="value-item">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      <span>100% Natural Stone</span>
    </div>

    <div class="value-sep"></div>

    <div class="value-item">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      <span>Eco-Friendly Packaging</span>
    </div>

    <div class="value-sep"></div>

    <div class="value-item">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
        <polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
      <span>Vegan & Non-Toxic</span>
    </div>

    <div class="value-sep"></div>

    <div class="value-item">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="1" y="3" width="15" height="13"/>
        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
        <circle cx="5.5" cy="18.5" r="2.5"/>
        <circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
      <span>Free Shipping Over &#8364;45</span>
    </div>

  </div>
</section>

<style>
.value-strip {
  background: var(--espresso, #1E120A);
  padding: 20px 48px;
  border-top: 1px solid rgba(247,242,234,0.06);
}
.value-strip-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32px;
  flex-wrap: wrap;
}
.value-item {
  display: flex;
  align-items: center;
  gap: 10px;
  color: rgba(247,242,234,0.45);
  transition: color 0.3s;
}
.value-item:hover {
  color: rgba(247,242,234,0.7);
}
.value-item svg {
  flex-shrink: 0;
  color: var(--terracotta, #B8704A);
  opacity: 0.7;
}
.value-item span {
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  white-space: nowrap;
}
.value-sep {
  width: 1px;
  height: 20px;
  background: rgba(247,242,234,0.1);
}

@media (max-width: 900px) {
  .value-strip { padding: 24px; }
  .value-strip-inner { gap: 20px; justify-content: flex-start; }
  .value-sep { display: none; }
  .value-item span { font-size: 10px; }
}
</style>

{% schema %}
{
  "name": "Value Props",
  "presets": [{ "name": "Value Props" }]
}
{% endschema %}
