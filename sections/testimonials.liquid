<section class="promise-section" id="reviews">

  <!-- Full-width image strip -->
  <div class="promise-image reveal">
    <img
      src="https://raw.githubusercontent.com/AppaaThe/Rituel-store/main/product-images/rituel-guasha-closeup-inuse.png"
      alt="Close-up of amethyst gua sha stone on skin"
      loading="lazy"
    >
    <div class="promise-image-overlay"></div>
    <div class="promise-image-text">
      <span class="promise-image-label">The Ritual</span>
      <h2 class="promise-image-title">Real results.<br><em>Real commitment.</em></h2>
      <p class="promise-image-sub">5 minutes every morning. That's the only secret.</p>
    </div>
  </div>

  <!-- Promise cards -->
  <div class="promise-cards">
    <div class="promise-cards-inner">

      <div class="promise-card reveal">
        <div class="promise-card-num">01</div>
        <div class="promise-card-body">
          <h3>Visible from day one</h3>
          <p>Gua sha physically moves fluid and boosts circulation. You'll see less puffiness after your very first session.</p>
        </div>
      </div>

      <div class="promise-card reveal reveal-delay-1">
        <div class="promise-card-num">02</div>
        <div class="promise-card-body">
          <h3>Better with consistency</h3>
          <p>Like any ritual, the results compound. By week 2-3, the difference becomes something other people notice.</p>
        </div>
      </div>

      <div class="promise-card reveal reveal-delay-2">
        <div class="promise-card-num">03</div>
        <div class="promise-card-body">
          <h3>Backed by your guarantee</h3>
          <p>Try it for 30 days. If you don't see results, we'll refund every penny. No questions, no hassle.</p>
        </div>
      </div>

    </div>
  </div>

</section>

<style>
/* ── Promise Section ── */
.promise-section {
  background: var(--cream);
}

/* Image strip */
.promise-image {
  position: relative;
  height: 60vh;
  min-height: 400px;
  max-height: 600px;
  overflow: hidden;
}
.promise-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
  display: block;
}
.promise-image-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(30,18,10,0.2) 0%, rgba(30,18,10,0.7) 100%);
}
.promise-image-text {
  position: absolute;
  bottom: 56px;
  left: 80px;
  z-index: 1;
}
.promise-image-label {
  display: block;
  font-size: 10px;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--terracotta);
  margin-bottom: 16px;
}
.promise-image-title {
  font-family: var(--serif);
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 300;
  color: var(--cream);
  line-height: 1.1;
  margin-bottom: 12px;
}
.promise-image-title em {
  font-style: italic;
  color: var(--blush);
}
.promise-image-sub {
  font-size: 14px;
  color: rgba(247,242,234,0.5);
  letter-spacing: 0.03em;
}

/* Cards */
.promise-cards {
  background: var(--cream);
  padding: 80px 80px;
}
.promise-cards-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--cream-dark);
}
.promise-card {
  display: flex;
  gap: 20px;
  padding: 40px 32px;
  background: var(--cream);
}
.promise-card-num {
  font-family: var(--serif);
  font-size: 40px;
  font-weight: 300;
  color: var(--terracotta);
  opacity: 0.4;
  line-height: 1;
  flex-shrink: 0;
}
.promise-card-body h3 {
  font-family: var(--serif);
  font-size: 18px;
  font-weight: 400;
  color: var(--espresso);
  margin-bottom: 10px;
  line-height: 1.3;
}
.promise-card-body p {
  font-size: 13px;
  line-height: 1.8;
  color: var(--stone);
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .promise-image-text { left: 32px; bottom: 40px; }
  .promise-cards { padding: 48px 32px; }
  .promise-cards-inner { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
  .promise-image { height: 50vh; min-height: 320px; }
  .promise-image-text { left: 20px; bottom: 28px; }
  .promise-cards { padding: 40px 16px; }
  .promise-card { padding: 28px 20px; }
}
</style>

{% schema %}
{
  "name": "Testimonials",
  "presets": [{ "name": "Testimonials" }]
}
{% endschema %}
