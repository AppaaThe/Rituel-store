{%- assign gua_sha = all_products['amethyst-gua-sha'] -%}
{%- assign roller  = all_products['rituel-amethyst-roller'] -%}
{%- assign ice     = all_products['rituel-ice-roller'] -%}
{%- assign oil     = all_products['rituel-rosehip-oil'] -%}

<section class="fp" id="shop">

  <header class="fp-head reveal">
    <p class="fp-eyebrow">The Tool</p>
    <h2 class="fp-title">One stone.<br>One ritual.</h2>
  </header>

  <div class="fp-layout">

    <!-- Hero card: Amethyst Gua Sha (with slideshow) -->
    <article class="fp-hero reveal" data-fp-slideshow>
      <div class="fp-hero-slideshow">
        <div class="fp-hero-slides" aria-roledescription="carousel" aria-label="Amethyst Gua Sha product photos">
          {%- assign gs_images = gua_sha.images -%}
          {%- if gs_images.size >= 2 -%}
            {%- for img in gs_images limit: 5 -%}
              <a href="{{ gua_sha.url }}"
                 class="fp-hero-slide{% if forloop.first %} is-active{% endif %}"
                 aria-label="Shop Amethyst Gua Sha — $22"
                 aria-roledescription="slide"
                 aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
                 tabindex="{% if forloop.first %}0{% else %}-1{% endif %}">
                <img src="{{ img | image_url: width: 900 }}"
                     alt="Amethyst gua sha — view {{ forloop.index }} of {{ gs_images.size }}"
                     loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                     width="900" height="1125">
              </a>
            {%- endfor -%}
          {%- else -%}
            {%- assign fallback = 'br-prod-guasha-hero.webp|br-guasha-closeup.webp|br-card-guasha-lifestyle.webp|br-hero-guasha-outdoor.webp' | split: '|' -%}
            {%- for asset in fallback -%}
              <a href="{{ gua_sha.url }}"
                 class="fp-hero-slide{% if forloop.first %} is-active{% endif %}"
                 aria-label="Shop Amethyst Gua Sha — $22"
                 aria-roledescription="slide"
                 aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
                 tabindex="{% if forloop.first %}0{% else %}-1{% endif %}">
                <img src="{{ asset | asset_url }}"
                     alt="Amethyst gua sha — view {{ forloop.index }} of {{ fallback.size }}"
                     loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                     width="900" height="1125">
              </a>
            {%- endfor -%}
          {%- endif -%}
        </div>
        <span class="fp-hero-badge">Best Seller</span>
        <div class="fp-hero-dots" role="tablist" aria-label="Product photo navigation"></div>
      </div>
      <div class="fp-hero-body">
        <p class="fp-hero-label">The Foundation</p>
        <h3 class="fp-hero-name">Amethyst Gua Sha</h3>
        <p class="fp-hero-copy">The single tool that does the most work. Sculpts the jawline, drains morning puffiness, releases the jaw clench you didn't know you were holding.</p>
        <a href="{{ gua_sha.url }}" class="fp-hero-cta" aria-label="Shop Amethyst Gua Sha — $22">
          <span class="fp-hero-cta-label">Shop the Foundation</span>
          <span class="fp-hero-cta-meta">$22 &nbsp;·&nbsp; <span class="fp-hero-cta-arrow" aria-hidden="true">&rarr;</span></span>
        </a>
      </div>
    </article>

    {%- comment -%}
      Supporting product stack hidden — gua-sha-only homepage focus.
      Bring back when other products are launch-ready.
      <div class="fp-stack reveal reveal-delay-1">
        ... rosehip oil / ice roller / amethyst roller cards ...
      </div>
    {%- endcomment -%}

  </div>

  {%- comment -%}
    "View all" link hidden alongside the stack — keep funnel focused on gua sha.
    <a href="{{ routes.collections_url }}/all" class="fp-viewall reveal">
      View all tools &amp; ritual sets &rarr;
    </a>
  {%- endcomment -%}

</section>

<style>
/* ── Featured Products: Hero-led asymmetric ── */
.fp {
  background: var(--espresso);
  padding: clamp(72px, 9vw, 120px) clamp(20px, 5vw, 80px);
  color: var(--cream);
}

/* Header */
.fp-head {
  max-width: 1320px;
  margin: 0 auto clamp(48px, 6vw, 80px);
  text-align: center;
}
.fp-eyebrow {
  font-family: var(--sans);
  font-size: 10px;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--terracotta);
  margin-bottom: 20px;
}
.fp-title {
  font-family: var(--serif);
  font-size: clamp(36px, 4.4vw, 60px);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.01em;
  color: var(--cream);
  margin: 0;
}

/* Layout: solo gua sha — full-width centered hero card */
.fp-layout {
  max-width: 1180px;
  margin: 0 auto;
  display: block;
}

/* Shared link reset (for anchor descendants of cards) */
.fp-row,
.fp-hero-slide {
  text-decoration: none;
  color: inherit;
  display: block;
}

/* ── Hero card (gua sha with slideshow) — horizontal solo layout ── */
.fp-hero {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
  background: rgba(255,255,255,0.025);
  border: 1px solid rgba(247,242,234,0.07);
  overflow: hidden;
  transition: border-color 0.4s var(--ease-premium), background 0.4s var(--ease-premium);
}
@media (max-width: 880px) {
  .fp-hero {
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
  }
}
.fp-hero:hover {
  border-color: rgba(184,112,74,0.4);
  background: rgba(255,255,255,0.045);
}
.fp-hero-slideshow {
  position: relative;
  aspect-ratio: 4 / 5;
  overflow: hidden;
  background: #2a1a10;
  touch-action: pan-y;
}
.fp-hero-slides {
  position: absolute;
  inset: 0;
}
.fp-hero-slide {
  position: absolute;
  inset: 0;
  text-decoration: none;
  color: inherit;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.6s var(--ease-premium), visibility 0s linear 0.6s;
  display: block;
}
.fp-hero-slide.is-active {
  opacity: 1;
  visibility: visible;
  transition: opacity 0.6s var(--ease-premium), visibility 0s linear 0s;
}
.fp-hero-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 1.2s var(--ease-smooth);
}
.fp-hero:hover .fp-hero-slide.is-active img {
  transform: scale(1.03);
}
.fp-hero-slide:focus-visible {
  outline: 2px solid var(--terracotta);
  outline-offset: -6px;
}
.fp-hero-badge {
  position: absolute;
  top: 20px;
  left: 20px;
  background: var(--terracotta);
  color: var(--cream);
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 7px 14px;
  z-index: 2;
  pointer-events: none;
}
.fp-hero-dots {
  position: absolute;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 8px;
  z-index: 2;
  padding: 8px 12px;
  background: rgba(30, 18, 10, 0.45);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  border-radius: 999px;
}
.fp-hero-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  border: 0;
  padding: 0;
  background: rgba(247, 242, 234, 0.4);
  cursor: pointer;
  transition: background 0.3s var(--ease-premium), transform 0.3s var(--ease-premium);
}
.fp-hero-dot:hover,
.fp-hero-dot:focus-visible {
  background: rgba(247, 242, 234, 0.75);
  transform: scale(1.2);
}
.fp-hero-dot:focus-visible {
  outline: 2px solid var(--cream);
  outline-offset: 2px;
}
.fp-hero-dot.is-active {
  background: var(--cream);
  transform: scale(1.2);
}
.fp-hero-body {
  padding: clamp(40px, 5vw, 72px) clamp(36px, 4.5vw, 60px);
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 18px;
}
@media (max-width: 880px) {
  .fp-hero-body {
    padding: clamp(28px, 5vw, 40px) clamp(24px, 5vw, 36px) clamp(32px, 6vw, 44px);
    gap: 16px;
  }
}
.fp-hero-label {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: var(--terracotta);
}
.fp-hero-name {
  font-family: var(--serif);
  font-size: clamp(28px, 2.6vw, 38px);
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: -0.005em;
  color: var(--cream);
  margin: 0;
}
.fp-hero-copy {
  font-family: var(--serif);
  font-size: clamp(16px, 1.3vw, 18px);
  font-weight: 400;
  line-height: 1.55;
  color: rgba(247,242,234,0.78);
  max-width: 38ch;
}
.fp-hero-cta {
  margin-top: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  background: var(--terracotta);
  color: var(--cream);
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 18px 24px;
  transition: background 0.3s var(--ease-premium);
}
.fp-hero:hover .fp-hero-cta {
  background: #8B4F33;
}
.fp-hero-cta-meta {
  display: inline-flex;
  align-items: center;
  letter-spacing: 0.1em;
}
.fp-hero-cta-arrow {
  display: inline-block;
  transition: transform 0.3s var(--ease-premium);
}
.fp-hero:hover .fp-hero-cta-arrow {
  transform: translateX(4px);
}

/* ── Stack of 3 supporting rows ── */
.fp-stack {
  display: grid;
  grid-auto-rows: auto;
  align-content: space-between;
  gap: clamp(12px, 1.5vw, 16px);
}
.fp-row {
  display: grid;
  grid-template-columns: minmax(120px, 38%) 1fr;
  gap: clamp(16px, 2vw, 24px);
  background: rgba(255,255,255,0.025);
  border: 1px solid rgba(247,242,234,0.07);
  overflow: hidden;
  transition: border-color 0.4s var(--ease-premium), background 0.4s var(--ease-premium);
}
.fp-row:hover {
  border-color: rgba(184,112,74,0.4);
  background: rgba(255,255,255,0.045);
}
.fp-row-img {
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #2a1a10;
}
.fp-row-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.7s var(--ease-smooth);
}
.fp-row:hover .fp-row-img img {
  transform: scale(1.04);
}
.fp-row-body {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: clamp(16px, 2vw, 24px) clamp(20px, 2.4vw, 28px) clamp(16px, 2vw, 24px) 0;
  gap: 6px;
}
.fp-row-label {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--terracotta);
}
.fp-row-name {
  font-family: var(--serif);
  font-size: clamp(18px, 1.6vw, 22px);
  font-weight: 400;
  line-height: 1.15;
  color: var(--cream);
  margin: 0;
}
.fp-row-copy {
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 400;
  line-height: 1.5;
  color: rgba(247,242,234,0.7);
  margin-top: 2px;
}
.fp-row-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-top: 10px;
}
.fp-row-price {
  font-family: var(--serif);
  font-size: 18px;
  color: var(--cream);
  letter-spacing: 0.01em;
}
.fp-row-arrow {
  font-family: var(--sans);
  font-size: 14px;
  color: var(--terracotta);
  transition: transform 0.3s var(--ease-premium);
  display: inline-block;
}
.fp-row:hover .fp-row-arrow {
  transform: translateX(4px);
}

/* View-all link */
.fp-viewall {
  display: block;
  width: max-content;
  margin: clamp(48px, 6vw, 72px) auto 0;
  font-family: var(--sans);
  font-size: 11px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--terracotta);
  text-decoration: none;
  border-bottom: 1px solid currentColor;
  padding: 8px 0;
  transition: color 0.3s var(--ease-premium);
}
.fp-viewall:hover {
  color: var(--cream);
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .fp-layout {
    grid-template-columns: 1fr;
    gap: clamp(16px, 3vw, 24px);
  }
  .fp-hero-slideshow {
    aspect-ratio: 5 / 4;
  }
}
@media (max-width: 640px) {
  .fp-row {
    grid-template-columns: 110px 1fr;
    gap: 14px;
  }
  .fp-row-body {
    padding: 14px 14px 14px 0;
  }
  .fp-row-copy {
    font-size: 12px;
    line-height: 1.45;
  }
  .fp-hero-cta {
    padding: 16px 20px;
    font-size: 11px;
  }
  .fp-hero-cta-label {
    letter-spacing: 0.15em;
  }
  .fp-hero-dots {
    bottom: 12px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .fp-hero,
  .fp-row,
  .fp-hero-slide,
  .fp-hero-slide img,
  .fp-row-img img,
  .fp-hero-cta,
  .fp-hero-cta-arrow,
  .fp-row-arrow,
  .fp-hero-dot {
    transition: none !important;
  }
}
</style>

<script>
  (function () {
    function initSlideshow(root) {
      var slides = root.querySelectorAll('.fp-hero-slide');
      if (slides.length < 2) return;
      var dotsContainer = root.querySelector('.fp-hero-dots');
      var slideshow = root.querySelector('.fp-hero-slideshow');
      var current = 0;
      var autoplayTimer = null;
      var AUTOPLAY_MS = 7000;
      var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      var dots = [];
      for (var i = 0; i < slides.length; i++) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'fp-hero-dot' + (i === 0 ? ' is-active' : '');
        btn.setAttribute('role', 'tab');
        btn.setAttribute('aria-label', 'Show product photo ' + (i + 1) + ' of ' + slides.length);
        btn.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
        btn.dataset.index = String(i);
        dotsContainer.appendChild(btn);
        dots.push(btn);
      }

      function goTo(index) {
        index = (index + slides.length) % slides.length;
        if (index === current) return;
        slides[current].classList.remove('is-active');
        slides[current].setAttribute('aria-hidden', 'true');
        slides[current].setAttribute('tabindex', '-1');
        dots[current].classList.remove('is-active');
        dots[current].setAttribute('aria-selected', 'false');
        current = index;
        slides[current].classList.add('is-active');
        slides[current].setAttribute('aria-hidden', 'false');
        slides[current].setAttribute('tabindex', '0');
        dots[current].classList.add('is-active');
        dots[current].setAttribute('aria-selected', 'true');
      }
      function next() { goTo(current + 1); }

      function startAutoplay() {
        if (reduceMotion) return;
        stopAutoplay();
        autoplayTimer = setInterval(next, AUTOPLAY_MS);
      }
      function stopAutoplay() {
        if (autoplayTimer) { clearInterval(autoplayTimer); autoplayTimer = null; }
      }

      dotsContainer.addEventListener('click', function (e) {
        var target = e.target.closest('.fp-hero-dot');
        if (!target) return;
        e.preventDefault();
        e.stopPropagation();
        goTo(parseInt(target.dataset.index, 10));
        stopAutoplay();
        startAutoplay();
      });

      dotsContainer.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowLeft') { e.preventDefault(); goTo(current - 1); stopAutoplay(); startAutoplay(); dots[current].focus(); }
        else if (e.key === 'ArrowRight') { e.preventDefault(); goTo(current + 1); stopAutoplay(); startAutoplay(); dots[current].focus(); }
      });

      slideshow.addEventListener('mouseenter', stopAutoplay);
      slideshow.addEventListener('mouseleave', startAutoplay);
      slideshow.addEventListener('focusin', stopAutoplay);
      slideshow.addEventListener('focusout', function (e) {
        // Only resume if focus actually left the slideshow container
        if (!slideshow.contains(e.relatedTarget)) startAutoplay();
      });

      var touchStartX = 0;
      slideshow.addEventListener('touchstart', function (e) {
        touchStartX = e.changedTouches[0].screenX;
        stopAutoplay();
      }, { passive: true });
      slideshow.addEventListener('touchend', function (e) {
        var dx = e.changedTouches[0].screenX - touchStartX;
        if (Math.abs(dx) > 40) {
          if (dx < 0) next();
          else goTo(current - 1);
        }
        startAutoplay();
      }, { passive: true });

      // Pause when tab hidden (bind once per instance, guard against dup mounts)
      if (!root.__fpVisBound) {
        root.__fpVisBound = true;
        document.addEventListener('visibilitychange', function () {
          if (document.hidden) stopAutoplay(); else startAutoplay();
        });
      }

      startAutoplay();
    }

    function init() {
      document.querySelectorAll('[data-fp-slideshow]').forEach(function (el) {
        if (el.__fpInit) return;
        el.__fpInit = true;
        initSlideshow(el);
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

{% schema %}
{
  "name": "Featured Products",
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
