<section class="products-section" id="shop">
  <div class="products-inner">
    <div class="products-header">
      <span class="section-label reveal">Complete Your Ritual</span>
      <h2 class="section-title reveal reveal-delay-1">Add to Your Order<br><em>& Save</em></h2>
    </div>
    <div class="products-grid">
      <div class="product-card reveal">
        <div class="product-icon">🌹</div>
        <div class="product-name">Ritual Facial Oil</div>
        <p class="product-desc">Rosehip + Vitamin C. The essential glide for your gua sha. Absorbs in seconds, never greasy.</p>
        <div class="product-price">$18 <span class="product-price-orig">$24</span></div>
        <button class="btn-secondary">Add to Order</button>
      </div>
      <div class="product-card featured reveal reveal-delay-1">
        <div class="product-featured-label">Best Value</div>
        <div class="product-icon">✨</div>
        <div class="product-name">Ritual Guidebook</div>
        <p class="product-desc">Digital PDF — technique diagrams, pressure point maps, 30-day challenge tracker. Delivered instantly.</p>
        <div class="product-price">$7 <span class="product-price-orig">$14</span></div>
        <button class="btn-secondary">Add to Order — $7</button>
      </div>
      <div class="product-card reveal reveal-delay-2">
        <div class="product-icon">💎</div>
        <div class="product-name">Jade Roller</div>
        <p class="product-desc">Pair with your gua sha for the complete tool set. Natural jade, weighted for perfect pressure.</p>
        <div class="product-price">$14 <span class="product-price-orig">$22</span></div>
        <button class="btn-secondary">Add to Order</button>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
