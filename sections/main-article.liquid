<article class="article-page">

  <header class="article-hero">
    <p class="article-eyebrow">The Ritual Guide</p>
    <h1>{{ article.title }}</h1>
    <p class="article-meta">BY RITUEL &nbsp;·&nbsp; {{ article.published_at | date: "%B %d, %Y" }} &nbsp;·&nbsp; {{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</p>
  </header>

  {% if article.image %}
    <div class="article-featured-img">
      <img src="{{ article.image | img_url: '1200x600', crop: 'center' }}" alt="{{ article.image.alt | escape }}" />
    </div>
  {% endif %}

  <div class="article-body">
    {{ article.content }}
  </div>

  <!-- SHOP THE RITUAL — conversion block for every blog reader -->
  <section class="article-shop" aria-labelledby="article-shop-title">
    <div class="article-shop-inner">
      <span class="article-shop-eyebrow">Shop The Ritual</span>
      <h2 id="article-shop-title" class="article-shop-title">The tools <em>we use every morning.</em></h2>
      <p class="article-shop-sub">Four hand-finished pieces. One 5-minute ritual. Free US shipping over $35.</p>

      <div class="article-shop-grid">
        <a href="/products/amethyst-gua-sha" class="article-shop-card">
          <div class="article-shop-img article-shop-img--guasha"></div>
          <div class="article-shop-card-body">
            <span class="article-shop-card-label">Amethyst Gua Sha</span>
            <span class="article-shop-card-price">$22</span>
          </div>
        </a>
        <a href="/products/rituel-jade-roller" class="article-shop-card">
          <div class="article-shop-img article-shop-img--roller"></div>
          <div class="article-shop-card-body">
            <span class="article-shop-card-label">Amethyst Roller</span>
            <span class="article-shop-card-price">$16</span>
          </div>
        </a>
        <a href="/products/rituel-ice-roller" class="article-shop-card">
          <div class="article-shop-img article-shop-img--ice"></div>
          <div class="article-shop-card-body">
            <span class="article-shop-card-label">Rose Ice Roller</span>
            <span class="article-shop-card-price">$19</span>
          </div>
        </a>
        <a href="/products/rituel-rosehip-oil" class="article-shop-card">
          <div class="article-shop-img article-shop-img--oil"></div>
          <div class="article-shop-card-body">
            <span class="article-shop-card-label">Rosehip Oil</span>
            <span class="article-shop-card-price">$15</span>
          </div>
        </a>
      </div>

      <div class="article-shop-cta-row">
        <a href="/collections/all" class="article-shop-cta-primary">Shop the Full Ritual</a>
        <a href="/products/rituel-complete-ritual" class="article-shop-cta-secondary">Or get the Complete Set — $58 →</a>
      </div>
    </div>
  </section>

  <!-- Related reading — internal linking boost -->
  {%- if blog.articles.size > 1 -%}
    <section class="article-related">
      <div class="article-related-inner">
        <span class="article-related-eyebrow">Keep Reading</span>
        <h2 class="article-related-title">More from <em>The Ritual Guide</em></h2>
        <div class="article-related-grid">
          {%- assign count = 0 -%}
          {%- for related in blog.articles -%}
            {%- if related.id != article.id and count < 3 -%}
              <a href="{{ related.url }}" class="article-related-card">
                <span class="article-related-card-label">{{ related.title }}</span>
                <span class="article-related-card-read">Read →</span>
              </a>
              {%- assign count = count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  <div class="article-footer">
    <a href="/collections/all" class="article-footer-cta">Shop BY RITUEL →</a>
  </div>

</article>

<style>
  .article-page {
    background: var(--cream, #FAF6F0);
    min-height: 100vh;
  }

  .article-hero {
    background: var(--espresso, #2C1810);
    padding: 100px 40px 80px;
    text-align: center;
  }

  .article-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--terracotta, #B8704A);
    margin-bottom: 24px;
  }

  .article-hero h1 {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: clamp(32px, 5vw, 58px);
    font-weight: 300;
    color: #FAF6F0;
    line-height: 1.15;
    max-width: 760px;
    margin: 0 auto 28px;
  }

  .article-meta {
    font-size: 13px;
    color: rgba(250,246,240,0.45);
    letter-spacing: 0.15em;
  }

  .article-featured-img {
    max-height: 480px;
    overflow: hidden;
  }

  .article-featured-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-body {
    max-width: 740px;
    margin: 0 auto;
    padding: 72px 32px 80px;
    font-family: var(--sans, 'Jost', sans-serif);
    font-size: 17px;
    line-height: 1.8;
    color: #3a2218;
  }

  .article-body h2 {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: clamp(26px, 3.5vw, 38px);
    font-weight: 400;
    color: var(--espresso, #2C1810);
    margin: 56px 0 20px;
    line-height: 1.2;
  }

  .article-body h3 {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--espresso, #2C1810);
    margin: 32px 0 12px;
  }

  .article-body p { margin-bottom: 24px; }
  .article-body strong { font-weight: 600; color: var(--espresso, #2C1810); }

  .article-body a {
    color: var(--terracotta, #B8704A);
    text-decoration: none;
    border-bottom: 1px solid rgba(123,94,167,0.3);
  }

  /* SHOP THE RITUAL block */
  .article-shop {
    background: var(--white, #FDFAF5);
    padding: 80px 32px;
    border-top: 1px solid rgba(30,18,10,0.08);
    border-bottom: 1px solid rgba(30,18,10,0.08);
  }
  .article-shop-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  .article-shop-eyebrow {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--terracotta, #A15E3C);
    margin-bottom: 18px;
  }
  .article-shop-title {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 300;
    color: var(--espresso, #1E120A);
    line-height: 1.15;
    margin-bottom: 14px;
  }
  .article-shop-title em { font-style: italic; color: var(--terracotta, #A15E3C); }
  .article-shop-sub {
    font-size: 15px;
    color: var(--stone, #6B5A40);
    margin-bottom: 48px;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }
  .article-shop-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }
  .article-shop-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease;
    border: 1px solid rgba(30,18,10,0.06);
    background: var(--cream, #F7F2EA);
  }
  .article-shop-card:hover { transform: translateY(-4px); }
  .article-shop-img {
    aspect-ratio: 1 / 1;
    background-size: cover;
    background-position: center;
    background-color: var(--cream-dark, #EDE6D6);
  }
  .article-shop-img--guasha { background-image: url('{{ 'br-prod-guasha-hero.webp' | asset_url }}'); }
  .article-shop-img--roller { background-image: url('{{ 'br-prod-roller-closeup.webp' | asset_url }}'); }
  .article-shop-img--ice { background-image: url('{{ 'br-prod-ice-hero.webp' | asset_url }}'); }
  .article-shop-img--oil { background-image: url('{{ 'br-prod-oil-hero.webp' | asset_url }}'); }
  .article-shop-card-body {
    padding: 18px 16px 22px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: center;
  }
  .article-shop-card-label {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: 17px;
    font-weight: 400;
    color: var(--espresso, #1E120A);
  }
  .article-shop-card-price {
    font-size: 13px;
    letter-spacing: 0.1em;
    color: var(--terracotta, #A15E3C);
  }
  .article-shop-cta-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .article-shop-cta-primary {
    display: inline-block;
    padding: 18px 44px;
    background: var(--espresso, #1E120A);
    color: var(--cream, #F7F2EA);
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 500;
    transition: background 0.3s;
  }
  .article-shop-cta-primary:hover { background: var(--terracotta, #A15E3C); }
  .article-shop-cta-secondary {
    font-size: 13px;
    color: var(--stone, #6B5A40);
    text-decoration: none;
    border-bottom: 1px solid rgba(107,90,64,0.3);
    padding-bottom: 2px;
    transition: color 0.3s;
  }
  .article-shop-cta-secondary:hover { color: var(--terracotta, #A15E3C); }

  /* RELATED READING block */
  .article-related {
    background: var(--cream, #F7F2EA);
    padding: 72px 32px;
  }
  .article-related-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  .article-related-eyebrow {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--terracotta, #A15E3C);
    margin-bottom: 14px;
  }
  .article-related-title {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 300;
    margin-bottom: 44px;
    color: var(--espresso, #1E120A);
  }
  .article-related-title em { font-style: italic; color: var(--terracotta, #A15E3C); }
  .article-related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .article-related-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 32px 28px;
    background: var(--white, #FDFAF5);
    border: 1px solid rgba(30,18,10,0.06);
    text-decoration: none;
    color: inherit;
    min-height: 160px;
    transition: border-color 0.3s;
    text-align: left;
  }
  .article-related-card:hover { border-color: var(--terracotta, #A15E3C); }
  .article-related-card-label {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: 20px;
    font-weight: 400;
    color: var(--espresso, #1E120A);
    line-height: 1.3;
    margin-bottom: 16px;
  }
  .article-related-card-read {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--terracotta, #A15E3C);
  }

  .article-footer {
    max-width: 740px;
    margin: 0 auto;
    padding: 60px 32px 80px;
    text-align: center;
  }
  .article-footer-cta {
    display: inline-block;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--espresso, #1E120A);
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--espresso, #1E120A);
    transition: color 0.3s, border-color 0.3s;
  }
  .article-footer-cta:hover {
    color: var(--terracotta, #A15E3C);
    border-color: var(--terracotta, #A15E3C);
  }

  /* Article Email Capture */
  .article-email-capture {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 32px 60px;
  }

  .capture-box {
    background: var(--espresso, #2C1810);
    padding: 48px 44px;
    text-align: center;
  }

  .capture-eyebrow {
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--terracotta, #B8704A);
    margin-bottom: 16px;
  }

  .capture-title {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: 28px;
    font-weight: 300;
    color: #FAF6F0;
    margin-bottom: 12px;
    line-height: 1.2;
  }

  .capture-desc {
    font-size: 14px;
    color: rgba(250,246,240,0.6);
    line-height: 1.6;
    margin-bottom: 24px;
    max-width: 460px;
    margin-left: auto;
    margin-right: auto;
  }

  .capture-form {
    display: flex;
    gap: 8px;
    max-width: 420px;
    margin: 0 auto 12px;
  }

  .capture-input {
    flex: 1;
    padding: 14px 18px;
    border: 1px solid rgba(250,246,240,0.15);
    background: rgba(250,246,240,0.08);
    font-family: inherit;
    font-size: 13px;
    color: #FAF6F0;
    outline: none;
    transition: border-color 0.3s;
  }

  .capture-input::placeholder { color: rgba(250,246,240,0.35); }
  .capture-input:focus { border-color: var(--terracotta, #B8704A); }

  .capture-btn {
    padding: 14px 24px;
    background: var(--terracotta, #C4714A);
    color: #FAF6F0;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    white-space: nowrap;
    transition: background 0.3s;
  }

  .capture-btn:hover { background: var(--terracotta, #B8704A); }

  .capture-note {
    font-size: 10px;
    color: rgba(250,246,240,0.3);
    text-align: center;
  }

  @media (max-width: 768px) {
    .capture-form { flex-direction: column; }
    .article-hero { padding: 80px 24px 60px; }
    .article-body { padding: 48px 20px 60px; }
    .article-shop { padding: 60px 20px; }
    .article-shop-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; margin-bottom: 36px; }
    .article-shop-cta-primary { padding: 16px 32px; font-size: 11px; }
    .article-related { padding: 56px 20px; }
    .article-related-grid { grid-template-columns: 1fr; gap: 14px; }
    .article-related-card { min-height: auto; padding: 24px 22px; }
  }
</style>

{% schema %}
{
  "name": "Article",
  "settings": []
}
{% endschema %}
