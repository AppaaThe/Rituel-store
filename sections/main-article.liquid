<article class="article-page">

  <header class="article-hero">
    <p class="article-eyebrow">The Ritual Guide</p>
    <h1>{{ article.title }}</h1>
    <p class="article-meta">BY RITUEL &nbsp;·&nbsp; {{ article.published_at | date: "%B %d, %Y" }} &nbsp;·&nbsp; {{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</p>
  </header>

  {% if article.image %}
    <div class="article-featured-img">
      <img src="{{ article.image | img_url: '1200x600', crop: 'center' }}" alt="{{ article.image.alt | escape }}" />
    </div>
  {% endif %}

  <div class="article-body">
    {{ article.content }}
  </div>

  <!-- INLINE EMAIL CAPTURE -->
  <div class="article-email-capture">
    <div class="capture-box">
      <p class="capture-eyebrow">Free guide</p>
      <h3 class="capture-title">Get the Complete Morning Ritual Guide</h3>
      <p class="capture-desc">The exact 5-minute gua sha technique for jawline definition, depuffing, and glowing skin. Plus 15% off your first order.</p>
      <form class="capture-form" action="/contact#contact_form" method="post" accept-charset="UTF-8">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[tags]" value="newsletter,blog,ritual-guide">
        <input class="capture-input" type="email" name="contact[email]" placeholder="Your email address" required>
        <button type="submit" class="capture-btn">Send Me the Guide</button>
      </form>
      <p class="capture-note">Free. No spam. Unsubscribe anytime.</p>
    </div>
  </div>

  <div class="article-footer">
    <a href="{{ blog.url }}" class="back-link">← Back to {{ blog.title }}</a>
  </div>

</article>

<style>
  .article-page {
    background: var(--cream, #FAF6F0);
    min-height: 100vh;
  }

  .article-hero {
    background: var(--espresso, #2C1810);
    padding: 100px 40px 80px;
    text-align: center;
  }

  .article-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--terracotta, #B8704A);
    margin-bottom: 24px;
  }

  .article-hero h1 {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: clamp(32px, 5vw, 58px);
    font-weight: 300;
    color: #FAF6F0;
    line-height: 1.15;
    max-width: 760px;
    margin: 0 auto 28px;
  }

  .article-meta {
    font-size: 13px;
    color: rgba(250,246,240,0.45);
    letter-spacing: 0.15em;
  }

  .article-featured-img {
    max-height: 480px;
    overflow: hidden;
  }

  .article-featured-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-body {
    max-width: 740px;
    margin: 0 auto;
    padding: 72px 32px 80px;
    font-family: var(--sans, 'Jost', sans-serif);
    font-size: 17px;
    line-height: 1.8;
    color: #3a2218;
  }

  .article-body h2 {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: clamp(26px, 3.5vw, 38px);
    font-weight: 400;
    color: var(--espresso, #2C1810);
    margin: 56px 0 20px;
    line-height: 1.2;
  }

  .article-body h3 {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--espresso, #2C1810);
    margin: 32px 0 12px;
  }

  .article-body p { margin-bottom: 24px; }
  .article-body strong { font-weight: 600; color: var(--espresso, #2C1810); }

  .article-body a {
    color: var(--terracotta, #B8704A);
    text-decoration: none;
    border-bottom: 1px solid rgba(123,94,167,0.3);
  }

  .article-footer {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 32px 80px;
    border-top: 1px solid rgba(44,24,16,0.1);
    padding-top: 40px;
  }

  .back-link {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--stone, #8B7355);
    text-decoration: none;
    transition: color 0.3s;
  }

  .back-link:hover { color: var(--terracotta, #B8704A); }

  /* Article Email Capture */
  .article-email-capture {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 32px 60px;
  }

  .capture-box {
    background: var(--espresso, #2C1810);
    padding: 48px 44px;
    text-align: center;
  }

  .capture-eyebrow {
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--terracotta, #B8704A);
    margin-bottom: 16px;
  }

  .capture-title {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: 28px;
    font-weight: 300;
    color: #FAF6F0;
    margin-bottom: 12px;
    line-height: 1.2;
  }

  .capture-desc {
    font-size: 14px;
    color: rgba(250,246,240,0.6);
    line-height: 1.6;
    margin-bottom: 24px;
    max-width: 460px;
    margin-left: auto;
    margin-right: auto;
  }

  .capture-form {
    display: flex;
    gap: 8px;
    max-width: 420px;
    margin: 0 auto 12px;
  }

  .capture-input {
    flex: 1;
    padding: 14px 18px;
    border: 1px solid rgba(250,246,240,0.15);
    background: rgba(250,246,240,0.08);
    font-family: inherit;
    font-size: 13px;
    color: #FAF6F0;
    outline: none;
    transition: border-color 0.3s;
  }

  .capture-input::placeholder { color: rgba(250,246,240,0.35); }
  .capture-input:focus { border-color: var(--terracotta, #B8704A); }

  .capture-btn {
    padding: 14px 24px;
    background: var(--terracotta, #C4714A);
    color: #FAF6F0;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    white-space: nowrap;
    transition: background 0.3s;
  }

  .capture-btn:hover { background: var(--terracotta, #B8704A); }

  .capture-note {
    font-size: 10px;
    color: rgba(250,246,240,0.3);
    text-align: center;
  }

  @media (max-width: 768px) {
    .capture-form { flex-direction: column; }
    .article-hero { padding: 80px 24px 60px; }
    .article-body { padding: 48px 20px 60px; }
  }
</style>

{% schema %}
{
  "name": "Article",
  "settings": []
}
{% endschema %}
