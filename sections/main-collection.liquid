<div class="collection-page">
  <span class="section-label">{{ collection.title }}</span>
  <h1 class="collection-title">{{ collection.title }}</h1>
  {%- if collection.description != blank -%}
    <p style="font-size:15px;color:var(--stone);line-height:1.8;max-width:560px;">{{ collection.description }}</p>
  {%- endif -%}
  <div class="collection-grid">
    {%- for product in collection.products -%}
      <a href="{{ product.url }}" class="collection-product" style="text-decoration:none;color:inherit;">
        <div class="collection-product-image">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">
          {%- else -%}
            <div style="width:100%;height:100%;background:radial-gradient(ellipse,#C8A882,#8B6845);"></div>
          {%- endif -%}
        </div>
        <div class="collection-product-name">{{ product.title }}</div>
        <div class="collection-product-price">{{ product.price | money }}</div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection",
  "presets": [{ "name": "Collection" }]
}
{% endschema %}
