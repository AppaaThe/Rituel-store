{%- comment -%} ── Shared image-base: use REAL product photos, not AI-generated ── {%- endcomment -%}
{%- assign real_base = 'https://cdn.jsdelivr.net/gh/AppaaThe/Rituel-store@main/product-images/' -%}

<div class="collection-page">

  {%- comment -%} HERO BANNER {%- endcomment -%}
  <div class="collection-hero">
    <img src="https://cdn.jsdelivr.net/gh/AppaaThe/Rituel-store@main/product-images/pg-page-hero-collection.png" alt="BY RITUEL editorial flatlay — amethyst gua sha, rose quartz roller and rosehip oil on cream linen" loading="eager">
    <div class="collection-hero-overlay"></div>
    <div class="collection-hero-content">
      <span class="section-label">The Collection</span>
      <h1 class="collection-hero-title">Tools for the <em>5-minute ritual.</em></h1>
      <p class="collection-hero-sub">Natural amethyst gua sha, rose quartz facial rollers, ice rollers and rosehip oil — curated to work as a single practice.</p>
    </div>
  </div>

  {%- comment -%} BUNDLES {%- endcomment -%}
  <div class="collection-block">
    <span class="section-label">Save More</span>
    <h2 class="collection-block-title">Ritual Sets</h2>
    <p class="collection-block-sub">Everything you need, bundled together. The more you commit to the ritual, the more you save.</p>
    <div class="collection-grid collection-grid-bundles">
      {%- for product in collection.products -%}
        {%- if product.tags contains 'bundle' -%}
          {%- assign h = product.handle | downcase -%}
          {%- assign nbp_hero = '' -%}
          {%- if h contains 'starter' -%}{%- assign nbp_hero = real_base | append: 'rituel-guasha-roller-set-amethyst.jpg' -%}
          {%- elsif h contains 'full' -%}{%- assign nbp_hero = real_base | append: 'rituel-guasha-amethyst-duo-white.png' -%}
          {%- elsif h contains 'ritual-kit' or h contains 'kit' -%}{%- assign nbp_hero = real_base | append: 'rituel-guasha-roller-duo-amethyst.jpg' -%}
          {%- endif -%}
          <a href="{{ product.url }}" class="collection-product" style="text-decoration:none;color:inherit;">
            <div class="collection-product-image">
              {%- if nbp_hero != '' -%}
                <img src="{{ nbp_hero }}" alt="{{ product.title | escape }}" loading="lazy">
              {%- elsif product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 700 }}" alt="{{ product.title }}" loading="lazy">
              {%- else -%}
                <div style="width:100%;height:100%;background:radial-gradient(ellipse,#C8A882,#8B6845);"></div>
              {%- endif -%}
              {%- if product.tags contains 'most popular' -%}
                <span class="collection-badge badge-pop">Most Popular</span>
              {%- elsif product.tags contains 'best value' -%}
                <span class="collection-badge badge-val">Best Value</span>
              {%- endif -%}
            </div>
            <div class="collection-product-name">{{ product.title }}</div>
            <div class="collection-product-price">
              {{ product.price | money }}
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} DIVIDER {%- endcomment -%}
  <div class="collection-divider"></div>

  {%- comment -%} INDIVIDUAL PRODUCTS {%- endcomment -%}
  <div class="collection-block">
    <span class="section-label">Individual Pieces</span>
    <h2 class="collection-block-title">Single Products</h2>
    <p class="collection-block-sub">Build your own ritual. Each tool works on its own — and even better together.</p>
    <div class="collection-grid">
      {%- for product in collection.products -%}
        {%- unless product.tags contains 'bundle' -%}
          {%- assign h = product.handle | downcase -%}
          {%- assign nbp_hero = '' -%}
          {%- if h contains 'gua' or h contains 'stone' -%}{%- assign nbp_hero = real_base | append: 'rituel-guasha-stone-amethyst.jpg' -%}
          {%- elsif h contains 'ice' -%}{%- assign nbp_hero = real_base | append: 'rituel-ice-roller-rose-pink.jpg' -%}
          {%- elsif h contains 'oil' or h contains 'rosehip' -%}{%- assign nbp_hero = real_base | append: 'rituel-rosehip-facial-oil-30ml.jpg' -%}
          {%- elsif h contains 'roller' -%}{%- assign nbp_hero = real_base | append: 'rituel-facial-roller-amethyst.jpg' -%}
          {%- endif -%}
          <a href="{{ product.url }}" class="collection-product" style="text-decoration:none;color:inherit;">
            <div class="collection-product-image">
              {%- if nbp_hero != '' -%}
                <img src="{{ nbp_hero }}" alt="{{ product.title | escape }}" loading="lazy">
              {%- elsif product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">
              {%- else -%}
                <div style="width:100%;height:100%;background:radial-gradient(ellipse,#C8A882,#8B6845);"></div>
              {%- endif -%}
            </div>
            <div class="collection-product-name">{{ product.title }}</div>
            <div class="collection-product-price">
              {{ product.price | money }}
            </div>
          </a>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>

</div>

<style>
.collection-hero {
  position: relative;
  width: 100%;
  height: 62vh;
  min-height: 440px;
  overflow: hidden;
  margin-bottom: 72px;
}
.collection-hero img {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center;
}
.collection-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(105deg, rgba(30,18,10,0.55) 0%, rgba(30,18,10,0.15) 55%, rgba(30,18,10,0) 100%);
}
.collection-hero-content {
  position: relative;
  max-width: 1200px;
  margin: 0 auto;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 80px;
  color: #FAF6F0;
}
.collection-hero .section-label { color: #E8C5B0; }
.collection-hero-title {
  font-family: var(--serif);
  font-size: clamp(44px, 6vw, 84px);
  font-weight: 300;
  line-height: 1.05;
  margin: 18px 0 24px;
  max-width: 680px;
}
.collection-hero-title em { font-style: italic; color: #E8C5B0; }
.collection-hero-sub {
  font-size: 17px;
  line-height: 1.7;
  max-width: 520px;
  color: rgba(250,246,240,0.85);
}
@media (max-width: 1024px) {
  .collection-hero { height: 54vh; min-height: 360px; margin-bottom: 48px; }
  .collection-hero-content { padding: 0 32px; }
}
</style>

{% schema %}
{
  "name": "Collection",
  "presets": [{ "name": "Collection" }]
}
{% endschema %}
