<section class="before-after-section">
  <div class="before-after-inner">

    <div class="before-after-header">
      <span class="section-label">Real Results</span>
      <h2 class="before-after-title">5 Minutes.<br><em>Every Morning.</em></h2>
      <p class="before-after-sub">Drag the slider to see the difference. Same woman, same day — before and after the ritual.</p>
    </div>

    <div class="ba-slider-wrap">
      <div class="ba-slider" id="baSlider">
        <!-- After image (full, sits behind) -->
        <img
          class="ba-img ba-img-after"
          src="https://raw.githubusercontent.com/AppaaThe/Rituel-store/main/product-images/rituel-glowing-skin-result.png"
          alt="After gua sha ritual — sculpted, glowing skin"
          loading="lazy"
          draggable="false"
        >
        <!-- Before image (clipped) -->
        <div class="ba-before-clip" id="baBeforeClip">
          <img
            class="ba-img ba-img-before"
            src="https://raw.githubusercontent.com/AppaaThe/Rituel-store/main/product-images/rituel-glowing-skin-result-2.png"
            alt="Before gua sha ritual — before the ritual"
            loading="lazy"
            draggable="false"
          >
        </div>
        <!-- Labels -->
        <div class="ba-label ba-label-before">Before</div>
        <div class="ba-label ba-label-after">After</div>
        <!-- Drag handle -->
        <div class="ba-handle" id="baHandle">
          <div class="ba-handle-line"></div>
          <div class="ba-handle-knob">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/><polyline points="9 18 15 12 9 6" transform="translate(6,0)"/></svg>
          </div>
          <div class="ba-handle-line"></div>
        </div>
      </div>

      <div class="ba-notes">
        <div class="ba-notes-col">
          <div class="comparison-note">&#x25CB; Under-eye puffiness</div>
          <div class="comparison-note">&#x25CB; Undefined jawline</div>
          <div class="comparison-note">&#x25CB; Dull, flat skin tone</div>
        </div>
        <div class="ba-notes-col ba-notes-after">
          <div class="comparison-note comparison-note-after">&#x2713; De-puffed, smooth under-eye</div>
          <div class="comparison-note comparison-note-after">&#x2713; Defined, sculpted jawline</div>
          <div class="comparison-note comparison-note-after">&#x2713; Lifted, glowing complexion</div>
        </div>
      </div>
    </div>

    <div class="before-after-cta">
      <p class="before-after-quote">&ldquo;I never skipped a morning after day 3. I couldn't — the difference is too obvious.&rdquo;</p>
      <a href="#shop" class="btn-primary" style="display:inline-block;width:auto;padding:20px 56px;text-decoration:none;">
        <span>Start Your Ritual</span>
      </a>
    </div>

  </div>
</section>

<style>
/* ── Before/After Slider ── */
.ba-slider-wrap {
  max-width: 520px;
  margin: 0 auto 72px;
}
.ba-slider {
  position: relative;
  overflow: hidden;
  cursor: ew-resize;
  user-select: none;
  -webkit-user-select: none;
  border-radius: 4px;
}
.ba-img {
  display: block;
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  pointer-events: none;
}
.ba-before-clip {
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
  height: 100%;
  overflow: hidden;
}
.ba-img-before {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  /* Match the container width so the image lines up exactly */
  min-width: 0;
}
.ba-before-clip .ba-img-before {
  /* Image must be sized to the full slider, not the clip */
  width: calc(100% / var(--ba-pos, 0.5));
  max-width: none;
}
/* Labels */
.ba-label {
  position: absolute;
  bottom: 20px;
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 6px 14px;
  border-radius: 2px;
  font-weight: 500;
  pointer-events: none;
  z-index: 3;
}
.ba-label-before {
  left: 16px;
  background: rgba(30,18,10,0.7);
  color: var(--cream, #FAF6F0);
}
.ba-label-after {
  right: 16px;
  background: var(--terracotta, #B8704A);
  color: #fff;
}
/* Handle */
.ba-handle {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 44px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 5;
  pointer-events: none;
}
.ba-handle-line {
  flex: 1;
  width: 2px;
  background: rgba(255,255,255,0.8);
}
.ba-handle-knob {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--cream, #FAF6F0);
  border: 2px solid rgba(255,255,255,0.9);
  box-shadow: 0 2px 12px rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--espresso, #2C1810);
  flex-shrink: 0;
}
/* Notes below slider */
.ba-notes {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  margin-top: 24px;
}
.ba-notes-col {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.ba-notes-after {
  text-align: right;
}

@media (max-width: 1024px) {
  .ba-slider-wrap { max-width: 100%; }
  .ba-notes { gap: 16px; }
}
@media (max-width: 520px) {
  .ba-notes { grid-template-columns: 1fr; gap: 20px; }
  .ba-notes-after { text-align: left; }
}
</style>

<script>
(function() {
  var slider = document.getElementById('baSlider');
  if (!slider) return;
  var clip = document.getElementById('baBeforeClip');
  var handle = document.getElementById('baHandle');
  var dragging = false;

  function setPosition(x) {
    var rect = slider.getBoundingClientRect();
    var pos = (x - rect.left) / rect.width;
    pos = Math.max(0.05, Math.min(0.95, pos));
    clip.style.width = (pos * 100) + '%';
    handle.style.left = (pos * 100) + '%';
    slider.style.setProperty('--ba-pos', pos);
  }

  // Set initial position
  setPosition(0);
  setTimeout(function() {
    var rect = slider.getBoundingClientRect();
    setPosition(rect.left + rect.width * 0.5);
  }, 100);

  slider.addEventListener('mousedown', function(e) {
    e.preventDefault();
    dragging = true;
    setPosition(e.clientX);
  });
  document.addEventListener('mousemove', function(e) {
    if (!dragging) return;
    setPosition(e.clientX);
  });
  document.addEventListener('mouseup', function() {
    dragging = false;
  });

  // Touch support
  slider.addEventListener('touchstart', function(e) {
    dragging = true;
    setPosition(e.touches[0].clientX);
  }, { passive: true });
  document.addEventListener('touchmove', function(e) {
    if (!dragging) return;
    setPosition(e.touches[0].clientX);
  }, { passive: true });
  document.addEventListener('touchend', function() {
    dragging = false;
  });
})();
</script>

{% schema %}
{
  "name": "Before After",
  "presets": [{ "name": "Before After" }]
}
{% endschema %}
