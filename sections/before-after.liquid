<section class="before-after-section">
  <div class="before-after-inner">

    <div class="before-after-header">
      <span class="section-label">Real Results</span>
      <h2 class="before-after-title">5 Minutes.<br><em>Every Morning.</em></h2>
      <p class="before-after-sub">No filters. No makeup. The same woman — before and after the ritual.</p>
    </div>

    <div class="before-after-comparison">

      <div class="comparison-side">
        <div class="comparison-img-wrap">
          <img
            src="https://raw.githubusercontent.com/AppaaThe/Rituel-store/main/product-images/rituel-before.png"
            alt="Before gua sha ritual — tired, puffy skin"
            loading="lazy"
          >
          <div class="comparison-label label-before">Before</div>
        </div>
        <div class="comparison-notes">
          <div class="comparison-note">&#x25CB; Under-eye puffiness</div>
          <div class="comparison-note">&#x25CB; Undefined jawline</div>
          <div class="comparison-note">&#x25CB; Dull, flat skin tone</div>
        </div>
      </div>

      <div class="comparison-divider">
        <div class="comparison-arrow">&#8594;</div>
        <div class="comparison-time">5 min</div>
      </div>

      <div class="comparison-side">
        <div class="comparison-img-wrap">
          <img
            src="https://raw.githubusercontent.com/AppaaThe/Rituel-store/main/product-images/rituel-after.png"
            alt="After gua sha ritual — sculpted, glowing skin"
            loading="lazy"
          >
          <div class="comparison-label label-after">After</div>
        </div>
        <div class="comparison-notes">
          <div class="comparison-note comparison-note-after">&#x2713; De-puffed, smooth under-eye</div>
          <div class="comparison-note comparison-note-after">&#x2713; Defined, sculpted jawline</div>
          <div class="comparison-note comparison-note-after">&#x2713; Lifted, glowing complexion</div>
        </div>
      </div>

    </div>

    <div class="before-after-cta">
      <p class="before-after-quote">&ldquo;I never skipped a morning after day 3. I couldn't — the difference is too obvious.&rdquo;</p>
      <a href="#shop" class="btn-primary" style="display:inline-block;width:auto;padding:20px 56px;text-decoration:none;">
        <span>Start Your Ritual</span>
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Before After",
  "presets": [{ "name": "Before After" }]
}
{% endschema %}
