<header class="site-header" id="siteHeader">
  <a href="{{ routes.root_url }}" class="header-logo">RITUEL</a>

  <nav class="header-nav" role="navigation">
    <a href="{{ routes.root_url }}">Home</a>
    <a href="{{ routes.collections_url }}/all">Shop</a>
    <a href="{{ pages['about-us'].url | default: '/pages/about-us' }}">About Us</a>
    <a href="{{ pages['faq'].url | default: '/pages/faq' }}">FAQ</a>
    <a href="/pages/contact">Contact</a>
  </nav>

  <div class="header-icons">
    <a href="{{ routes.cart_url }}" class="header-cart" aria-label="Shopping cart">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      {%- if cart.item_count > 0 -%}
        <span class="cart-count">{{ cart.item_count }}</span>
      {%- else -%}
        <span class="cart-count" style="display:none;">0</span>
      {%- endif -%}
    </a>

    <button class="hamburger" id="hamburger" aria-label="Open menu" onclick="toggleMenu()">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
  <div class="mobile-menu-inner">
    <a href="{{ routes.root_url }}" onclick="toggleMenu()">Home</a>
    <a href="{{ routes.collections_url }}/all" onclick="toggleMenu()">Shop</a>
    <a href="{{ pages['about-us'].url | default: '/pages/about-us' }}" onclick="toggleMenu()">About Us</a>
    <a href="{{ pages['faq'].url | default: '/pages/faq' }}" onclick="toggleMenu()">FAQ</a>
    <a href="/pages/contact" onclick="toggleMenu()">Contact</a>
    <a href="{{ routes.cart_url }}" onclick="toggleMenu()">Cart ({{ cart.item_count }})</a>
  </div>
</div>
<div class="mobile-overlay" id="mobileOverlay" onclick="toggleMenu()"></div>

<style>
.site-header {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 48px;
  height: 72px;
  transition: background 0.3s, box-shadow 0.3s;
}
.site-header::before {
  content: '';
  position: absolute; inset: 0;
  background: rgba(247,242,234,0.96);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(30,18,10,0.06);
  pointer-events: none;
  z-index: 0;
}
.site-header.scrolled::before {
  background: rgba(247,242,234,0.99);
  box-shadow: 0 2px 24px rgba(30,18,10,0.06);
}

.header-logo {
  font-family: var(--serif);
  font-size: 20px;
  letter-spacing: 0.28em;
  color: var(--espresso);
  text-decoration: none;
  font-weight: 400;
  position: relative;
  z-index: 1;
  transition: color 0.3s;
}
.header-logo:hover { color: var(--terracotta); }

.header-nav {
  display: flex; align-items: center; gap: 36px;
  position: relative; z-index: 1;
}
.header-nav a {
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--stone);
  text-decoration: none;
  transition: color 0.3s;
  position: relative;
  padding-bottom: 2px;
}
.header-nav a::after {
  content: '';
  position: absolute; bottom: -2px; left: 0; right: 0;
  height: 1px;
  background: var(--terracotta);
  transform: scaleX(0);
  transition: transform 0.3s ease;
  transform-origin: left;
}
.header-nav a:hover { color: var(--terracotta); }
.header-nav a:hover::after { transform: scaleX(1); }
.header-nav a.active { color: var(--espresso); }
.header-nav a.active::after { transform: scaleX(1); }

.header-icons {
  display: flex; align-items: center; gap: 20px;
  position: relative; z-index: 1;
}

.header-cart {
  display: flex; align-items: center;
  color: var(--espresso);
  text-decoration: none;
  position: relative;
  transition: color 0.3s;
}
.header-cart:hover { color: var(--terracotta); }
.cart-count {
  position: absolute; top: -8px; right: -10px;
  width: 17px; height: 17px;
  background: var(--terracotta);
  color: white; border-radius: 50%;
  font-size: 9px; font-weight: 500;
  display: flex; align-items: center; justify-content: center;
  transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
.cart-count.bump { transform: scale(1.5); }

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column; justify-content: center; align-items: center;
  gap: 5px; width: 32px; height: 32px;
  background: none; border: none; cursor: pointer; padding: 4px;
}
.hamburger span {
  display: block; width: 22px; height: 1.5px;
  background: var(--espresso);
  transition: all 0.3s ease;
  transform-origin: center;
}
.hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

/* Mobile Menu */
.mobile-menu {
  position: fixed; top: 0; right: 0; bottom: 0;
  width: 300px;
  background: var(--white);
  z-index: 200;
  transform: translateX(100%);
  transition: transform 0.4s cubic-bezier(0.23,1,0.32,1);
  display: flex; align-items: center;
}
.mobile-menu.open { transform: translateX(0); }
.mobile-menu-inner {
  display: flex; flex-direction: column;
  padding: 80px 48px;
  gap: 8px; width: 100%;
}
.mobile-menu-inner a {
  font-family: var(--serif);
  font-size: 30px;
  font-weight: 300;
  color: var(--espresso);
  text-decoration: none;
  padding: 12px 0;
  border-bottom: 1px solid var(--cream-dark);
  transition: color 0.3s, padding-left 0.3s;
}
.mobile-menu-inner a:hover { color: var(--terracotta); padding-left: 8px; }
.mobile-menu-inner a:last-child { border-bottom: none; }

.mobile-overlay {
  position: fixed; inset: 0;
  background: rgba(30,18,10,0.4);
  z-index: 199;
  opacity: 0; pointer-events: none;
  transition: opacity 0.4s;
}
.mobile-overlay.open { opacity: 1; pointer-events: all; }

@media (max-width: 900px) {
  .site-header { padding: 0 32px; }
  .header-nav { display: none; }
  .hamburger { display: flex; }
}
</style>

<script>
function toggleMenu() {
  const menu = document.getElementById('mobileMenu');
  const overlay = document.getElementById('mobileOverlay');
  const burger = document.getElementById('hamburger');
  menu.classList.toggle('open');
  overlay.classList.toggle('open');
  burger.classList.toggle('open');
}

// Highlight active nav link
const currentPath = window.location.pathname;
document.querySelectorAll('.header-nav a').forEach(link => {
  if (link.getAttribute('href') === currentPath ||
     (currentPath === '/' && link.getAttribute('href') === '/')) {
    link.classList.add('active');
  }
});

// Scroll effect
window.addEventListener('scroll', () => {
  const header = document.getElementById('siteHeader');
  if (window.scrollY > 20) {
    header.classList.add('scrolled');
  } else {
    header.classList.remove('scrolled');
  }
});
</script>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
