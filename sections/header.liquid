<style>
.site-header {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 48px;
  height: 72px;
  transition: background 0.3s, box-shadow 0.3s;
}
.site-header::before {
  content: '';
  position: absolute; inset: 0;
  background: rgba(247,242,234,0.96);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(30,18,10,0.06);
  pointer-events: none;
  z-index: 0;
}
.site-header.scrolled::before {
  background: rgba(247,242,234,0.99);
  box-shadow: 0 2px 24px rgba(30,18,10,0.06);
}

.header-logo {
  font-family: var(--serif);
  font-size: 20px;
  letter-spacing: 0.28em;
  color: var(--espresso);
  text-decoration: none;
  font-weight: 400;
  position: relative;
  z-index: 1;
  transition: color 0.3s;
}
.header-logo:hover { color: var(--terracotta); }

.header-nav {
  display: flex; align-items: center; gap: 36px;
  position: relative; z-index: 1;
}
.header-nav a {
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--stone);
  text-decoration: none;
  transition: color 0.3s;
  position: relative;
  padding-bottom: 2px;
}
.header-nav a::after {
  content: '';
  position: absolute; bottom: -2px; left: 0; right: 0;
  height: 1px;
  background: var(--terracotta);
  transform: scaleX(0);
  transition: transform 0.3s ease;
  transform-origin: left;
}
.header-nav a:hover { color: var(--terracotta); }
.header-nav a:hover::after { transform: scaleX(1); }
.header-nav a.active { color: var(--espresso); }
.header-nav a.active::after { transform: scaleX(1); }

.header-icons {
  display: flex; align-items: center; gap: 20px;
  position: relative; z-index: 1;
}

.header-cart {
  display: flex; align-items: center;
  color: var(--espresso);
  text-decoration: none;
  position: relative;
  transition: color 0.3s;
}
.header-cart:hover { color: var(--terracotta); }
.cart-count {
  position: absolute; top: -8px; right: -10px;
  width: 17px; height: 17px;
  background: var(--terracotta);
  color: white; border-radius: 50%;
  font-size: 9px; font-weight: 500;
  display: flex; align-items: center; justify-content: center;
  transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
.cart-count.bump { transform: scale(1.5); }

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column; justify-content: center; align-items: center;
  gap: 5px; width: 32px; height: 32px;
  background: none; border: none; cursor: pointer; padding: 4px;
}
.hamburger span {
  display: block; width: 22px; height: 1.5px;
  background: var(--espresso);
  transition: all 0.3s ease;
  transform-origin: center;
}
.hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

/* Mobile Menu */
.mobile-menu {
  position: fixed; top: 0; right: 0; bottom: 0;
  width: 300px;
  background: var(--white);
  z-index: 200;
  transform: translateX(100%);
  transition: transform 0.4s cubic-bezier(0.23,1,0.32,1);
  display: flex; align-items: center;
}
.mobile-menu.open { transform: translateX(0); }
.mobile-menu-inner {
  display: flex; flex-direction: column;
  padding: 80px 48px;
  gap: 8px; width: 100%;
}
.mobile-menu-inner a {
  font-family: var(--serif);
  font-size: 30px;
  font-weight: 300;
  color: var(--espresso);
  text-decoration: none;
  padding: 12px 0;
  border-bottom: 1px solid var(--cream-dark);
  transition: color 0.3s, padding-left 0.3s;
}
.mobile-menu-inner a:hover { color: var(--terracotta); padding-left: 8px; }
.mobile-menu-inner a:last-child { border-bottom: none; }

.mobile-menu-section {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 8px 0;
}
.mobile-menu-label {
  font-size: 9px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--terracotta, #B8704A);
  padding: 8px 0 12px;
}
.mobile-menu-sub {
  font-family: var(--sans, 'Jost', sans-serif);
  font-size: 15px;
  font-weight: 300;
  color: var(--stone, #8B7355);
  text-decoration: none;
  padding: 8px 0 8px 16px;
  border-bottom: none !important;
  transition: color 0.3s, padding-left 0.3s;
}
.mobile-menu-sub:hover { color: var(--terracotta); padding-left: 24px; }

.mobile-overlay {
  position: fixed; inset: 0;
  background: rgba(30,18,10,0.4);
  z-index: 199;
  opacity: 0; pointer-events: none;
  transition: opacity 0.4s;
}
.mobile-overlay.open { opacity: 1; pointer-events: all; }

/* Announcement Bar */
.announcement-bar {
  background: var(--espresso, #2C1810);
  color: var(--cream, #FAF6F0);
  text-align: center;
  padding: 10px 24px;
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  overflow: hidden;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 101;
}
.announcement-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  animation: announcement-scroll 20s linear infinite;
  white-space: nowrap;
}
.announcement-sep { color: #C4714A; font-size: 8px; }
@keyframes announcement-scroll {
  0%, 100% { transform: translateX(0); }
}

/* Popup Overlay */
.popup-overlay {
  position: fixed; inset: 0;
  background: rgba(30,18,10,0.55);
  z-index: 500;
  opacity: 0; pointer-events: none;
  transition: opacity 0.4s ease;
  display: flex; align-items: center; justify-content: center;
}
.popup-overlay.active { opacity: 1; pointer-events: all; }

.popup-box {
  background: var(--cream, #FAF6F0);
  max-width: 440px;
  width: 90%;
  padding: 48px 40px;
  position: relative;
  text-align: center;
  transform: translateY(24px) scale(0.96);
  transition: transform 0.4s cubic-bezier(0.23,1,0.32,1);
  border: 1px solid rgba(30,18,10,0.08);
}
.popup-overlay.active .popup-box {
  transform: translateY(0) scale(1);
}

.popup-close {
  position: absolute; top: 16px; right: 20px;
  background: none; border: none; cursor: pointer;
  font-size: 20px; color: #8A7060;
  transition: color 0.3s;
}
.popup-close:hover { color: #2C1810; }

.popup-eyebrow {
  font-size: 9px; letter-spacing: 4px; text-transform: uppercase;
  color: #C4714A; margin-bottom: 16px;
}
.popup-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px; font-weight: 300; line-height: 1.1;
  color: #2C1810; margin-bottom: 8px;
}
.popup-title em { font-style: italic; color: #C4714A; }
.popup-desc {
  font-size: 13px; color: #8A7060; line-height: 1.6;
  margin-bottom: 24px;
}
.popup-form {
  display: flex; gap: 8px; margin-bottom: 12px;
}
.popup-input {
  flex: 1; padding: 14px 18px;
  border: 1px solid #E8DDD0; background: white;
  font-family: inherit; font-size: 13px; color: #2C1810;
  outline: none; transition: border-color 0.3s;
}
.popup-input:focus { border-color: #C4714A; }
.popup-btn {
  padding: 14px 24px;
  background: #2C1810; color: #FAF6F0;
  border: none; cursor: pointer;
  font-family: inherit; font-size: 11px;
  letter-spacing: 0.15em; text-transform: uppercase;
  transition: background 0.3s;
}
.popup-btn:hover { background: #C4714A; }
.popup-note {
  font-size: 10px; color: #B0A090; letter-spacing: 0.5px;
}
.popup-success {
  display: none;
}
.popup-success.show {
  display: block;
}
.popup-success p {
  font-family: 'Cormorant Garamond', serif;
  font-size: 24px; font-weight: 300; color: #2C1810;
  margin-bottom: 8px;
}
.popup-success span {
  font-size: 12px; color: #8A7060;
}

/* Mega Menu */
.nav-dropdown-wrap {
  position: relative;
}
.nav-dropdown-trigger {
  cursor: pointer;
}
.nav-mega-menu {
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%) translateY(8px);
  background: var(--white, #FDFAF5);
  border: 1px solid rgba(30,18,10,0.08);
  box-shadow: 0 12px 40px rgba(30,18,10,0.1);
  padding: 32px 36px;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 36px;
  min-width: 520px;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease, transform 0.25s ease;
  z-index: 200;
}
.nav-dropdown-wrap:hover .nav-mega-menu {
  opacity: 1;
  pointer-events: all;
  transform: translateX(-50%) translateY(0);
}
.mega-col {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.mega-col-title {
  font-size: 9px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--terracotta, #B8704A);
  font-weight: 500;
  margin-bottom: 8px;
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(30,18,10,0.06);
}
.mega-link {
  font-size: 13px;
  color: var(--stone, #8B7355);
  text-decoration: none;
  transition: color 0.2s, padding-left 0.2s;
  padding: 4px 0;
  letter-spacing: 0;
  text-transform: none;
}
.mega-link:hover {
  color: var(--espresso, #1E120A);
  padding-left: 6px;
}
.mega-link::after {
  display: none;
}

@media (max-width: 900px) {
  .site-header { padding: 0 32px; }
  .header-nav { display: none; }
  .hamburger { display: flex; }
  .announcement-inner { font-size: 9px; gap: 12px; }
  .popup-form { flex-direction: column; }
  .nav-mega-menu { display: none; }
}
</style>

<script>
function toggleMenu() {
  const menu = document.getElementById('mobileMenu');
  const overlay = document.getElementById('mobileOverlay');
  const burger = document.getElementById('hamburger');
  menu.classList.toggle('open');
  overlay.classList.toggle('open');
  burger.classList.toggle('open');
}

// Highlight active nav link
const currentPath = window.location.pathname;
document.querySelectorAll('.header-nav a').forEach(link => {
  if (link.getAttribute('href') === currentPath ||
     (currentPath === '/' && link.getAttribute('href') === '/')) {
    link.classList.add('active');
  }
});

// Scroll effect
window.addEventListener('scroll', () => {
  const header = document.getElementById('siteHeader');
  if (window.scrollY > 20) {
    header.classList.add('scrolled');
  } else {
    header.classList.remove('scrolled');
  }
});
</script>

<!-- Email Popup -->
<div class="popup-overlay" id="popupOverlay">
  <div class="popup-box">
    <button class="popup-close" id="popupClose" aria-label="Close">&times;</button>
    <div id="popupContent">
      <div class="popup-eyebrow">Free guide + 10% off</div>
      <h3 class="popup-title">The 5-Minute<br><em>Sculpting Ritual</em></h3>
      <p class="popup-desc">Get our free Morning Ritual Guide — the exact technique for jawline definition, depuffing, and glowing skin in 5 minutes. Plus 10% off your first order.</p>
      <form class="popup-form" id="popupForm" action="/contact#contact_form" method="post" accept-charset="UTF-8">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[tags]" value="newsletter,popup,welcome10">
        <label for="popupEmail" class="sr-only">Email address</label>
        <input class="popup-input" type="email" name="contact[email]" id="popupEmail" placeholder="Your email address" aria-label="Email address" autocomplete="email" required>
        <button type="submit" class="popup-btn">Send Me the Free Guide</button>
      </form>
      <p class="popup-note">No spam. Unsubscribe anytime.</p>
    </div>
    <div class="popup-success" id="popupSuccess">
      <p>Welcome to the ritual.</p>
      <span>Check your email for your 10% discount code.</span>
    </div>
  </div>
</div>

<script>
// Popup logic — show after 8 seconds, only once per session
(function() {
  var shown = sessionStorage.getItem('rituel_popup');
  if (!shown) {
    setTimeout(function() {
      document.getElementById('popupOverlay').classList.add('active');
      sessionStorage.setItem('rituel_popup', '1');
    }, 5000);
  }

  // Exit intent — show popup when mouse leaves viewport
  document.addEventListener('mouseout', function(e) {
    if (e.clientY < 10 && !sessionStorage.getItem('rituel_popup')) {
      document.getElementById('popupOverlay').classList.add('active');
      sessionStorage.setItem('rituel_popup', '1');
    }
  });

  document.getElementById('popupClose').addEventListener('click', function() {
    document.getElementById('popupOverlay').classList.remove('active');
  });

  document.getElementById('popupOverlay').addEventListener('click', function(e) {
    if (e.target === this) this.classList.remove('active');
  });

  document.getElementById('popupForm').addEventListener('submit', function(e) {
    var email = document.getElementById('popupEmail').value;
    // Track in Klaviyo
    if (email && window._learnq) {
      window._learnq.push(['identify', { '$email': email }]);
      window._learnq.push(['track', 'Popup Signup', { source: 'popup', offer: '10_percent' }]);
    }
    // Show success state after short delay
    setTimeout(function() {
      document.getElementById('popupContent').style.display = 'none';
      document.getElementById('popupSuccess').classList.add('show');
      setTimeout(function() {
        document.getElementById('popupOverlay').classList.remove('active');
      }, 3000);
    }, 500);
  });
})();

// Adjust header position for announcement bar
(function() {
  var bar = document.getElementById('announcementBar');
  var header = document.getElementById('siteHeader');
  if (bar && header) {
    var barHeight = bar.offsetHeight;
    header.style.top = barHeight + 'px';
    document.body.style.paddingTop = (barHeight + 72) + 'px';
  }
})();
</script>

