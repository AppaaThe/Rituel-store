<div class="product-page">

  <!-- IMAGE GALLERY -->
  <div class="product-media">
    <div class="product-gallery">
      {%- for image in product.images -%}
        <img
          src="{{ image | image_url: width: 900 }}"
          alt="{{ image.alt | default: product.title | escape }}"
          class="product-gallery-img {% if forloop.first %}active{% endif %}"
          data-index="{{ forloop.index0 }}"
          loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          onclick="switchImage({{ forloop.index0 }})"
        >
      {%- endfor -%}
      {%- if product.images.size == 0 -%}
        <div class="gallery-placeholder"></div>
      {%- endif -%}
    </div>
    <div class="product-main-image">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 900 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          class="product-main-img"
          id="mainProductImage"
          loading="eager"
        >
      {%- else -%}
        <div class="gallery-placeholder"></div>
      {%- endif -%}
    </div>
  </div>

  <!-- PRODUCT INFO -->
  <div class="product-info">

    <p class="product-vendor">{{ product.vendor }}</p>
    <h1 class="product-title">{{ product.title }}</h1>

    <!-- Reviews will show here once real customers leave them -->

    <div class="product-price-wrap">
      <span class="product-page-price">{{ product.price | money }}</span>
      <!-- Compare-at pricing removed — clean single price, no fake sales -->
    </div>

    {%- if product.tags contains 'most popular' -%}
      <div class="product-tag-badge badge-popular">&#11088; Most Popular</div>
    {%- elsif product.tags contains 'best value' -%}
      <div class="product-tag-badge badge-value">Best Value</div>
    {%- endif -%}

    <!-- URGENCY -->
    <div class="product-urgency">
      <span class="urgency-dot"></span>
      <span class="urgency-text"><strong>12 people</strong> are viewing this right now</span>
    </div>

    <div class="product-description">{{ product.description }}</div>

    {%- form 'product', product -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <button type="submit" class="btn-primary btn-add-cart" {% unless product.available %}disabled{% endunless %}>
        <span>{% if product.available %}Add to Ritual — {{ product.price | money }}{% else %}Sold Out{% endif %}</span>
      </button>
    {%- endform -%}

    <!-- TRUST BADGES -->
    <div class="product-trust-grid">
      <div class="trust-badge">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12l5 5L20 7"/></svg>
        <div>
          <strong>Free Shipping</strong>
          <span>On orders over $45</span>
        </div>
      </div>
      <div class="trust-badge">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <div>
          <strong>30-Day Guarantee</strong>
          <span>Full refund, no questions</span>
        </div>
      </div>
      <div class="trust-badge">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        <div>
          <strong>Fast Delivery</strong>
          <span>Ships within 24 hours</span>
        </div>
      </div>
      <div class="trust-badge">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        <div>
          <strong>Natural Amethyst</strong>
          <span>Each stone is unique</span>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- WHAT'S INCLUDED -->
