  line-height: 1.1;
  margin: 18px 0 18px;
  color: var(--espresso);
}
.product-problems .section-title em { font-style: italic; color: var(--terracotta); }
.product-problems-sub {
  font-size: 16px;
  line-height: 1.7;
  color: var(--stone);
  max-width: 560px;
  margin: 0 auto 56px;
}
.problems-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2px;
  background: var(--cream-dark, #EDE6D6);
  text-align: left;
}
.problem-card {
  background: var(--white, #FFFFFF);
  padding: 52px 44px 48px;
  position: relative;
  overflow: hidden;
  transition: transform 0.45s cubic-bezier(.23,1,.32,1);
}
.problem-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 0;
  height: 3px;
  background: var(--terracotta, #A15E3C);
  transition: width 0.6s cubic-bezier(.23,1,.32,1);
}
.problem-card:hover {
  transform: translateY(-3px);
}
.problem-card:hover::before { width: 100%; }
.problem-icon {
  display: block;
  font-family: var(--serif);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.22em;
  color: var(--terracotta);
  margin-bottom: 22px;
  line-height: 1;
}
.problem-card h4 {
  font-family: var(--serif);
  font-size: 24px;
  font-weight: 400;
  color: var(--espresso);
  line-height: 1.25;
  margin: 0 0 14px;
  max-width: 90%;
}
.problem-card p {
  font-size: 14px;
  line-height: 1.85;
  color: var(--stone);
  margin: 0;
  max-width: 90%;
}
@media (max-width: 768px) {
  .product-problems { padding: 72px 20px; }
  .problems-grid { grid-template-columns: 1fr; }
  .problem-card { padding: 36px 28px; }
}

/* ── PRODUCT SECTIONS ── */
.product-section {
  padding: 80px 48px;
  max-width: 1100px;
  margin: 0 auto;
}

.product-section--dark {
  background: var(--espresso, #1E120A);
  max-width: 100%;
  text-align: center;
}

.section-title {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: clamp(28px, 3.5vw, 42px);
  font-weight: 400;
  color: var(--espresso, #1E120A);
  text-align: center;
  margin-bottom: 48px;
}

.section-title em { color: var(--terracotta, #A15E3C); font-style: italic; }
.section-title--light { color: var(--cream, #F7F2EA); }
.section-title--light em { color: var(--blush, #E8C5B0); }

.section-subtitle {
  font-size: 16px;
  color: rgba(250,246,240,0.5);
  text-align: center;
  margin-top: -32px;
  margin-bottom: 48px;
}

.section-label--light {
  color: var(--blush, #E8C5B0);
}

/* Scroll-reveal base */
.reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.9s cubic-bezier(.23,1,.32,1), transform 0.9s cubic-bezier(.23,1,.32,1);
}
.reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}
@media (prefers-reduced-motion: reduce) {
  .reveal { opacity: 1; transform: none; transition: none; }
}
.problem-card.reveal { transition-delay: 0.05s; }
.problem-card.reveal:nth-child(2) { transition-delay: 0.12s; }
.problem-card.reveal:nth-child(3) { transition-delay: 0.19s; }
.problem-card.reveal:nth-child(4) { transition-delay: 0.26s; }
.timeline-node.reveal { transition-delay: 0.08s; }
.timeline-node.reveal:nth-child(3) { transition-delay: 0.18s; }
.timeline-node.reveal:nth-child(4) { transition-delay: 0.28s; }
.lineage-card.reveal { transition-delay: 0.05s; }
.lineage-card.reveal:nth-child(2) { transition-delay: 0.14s; }
.lineage-card.reveal:nth-child(3) { transition-delay: 0.23s; }

/* Results Timeline */
.results-timeline {
  position: relative;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px;
  max-width: 980px;
  margin: 0 auto;
  padding: 48px 20px 8px;
}
.timeline-track {
  position: absolute;
  top: 66px;
  left: 12%;
  right: 12%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(232,197,176,0.4) 10%, rgba(232,197,176,0.4) 90%, transparent);
  pointer-events: none;
}
.timeline-node {
  position: relative;
  text-align: center;
  padding: 40px 12px 8px;
}
.timeline-dot {
  position: absolute;
  top: 18px;
  left: 50%;
  width: 14px;
  height: 14px;
  background: var(--espresso, #1E120A);
  border: 2px solid var(--blush, #E8C5B0);
  border-radius: 50%;
  transform: translateX(-50%);
  z-index: 2;
  transition: transform 0.4s, background 0.4s;
}
.timeline-node:hover .timeline-dot {
  background: var(--terracotta, #A15E3C);
  transform: translateX(-50%) scale(1.3);
}
.timeline-label {
  font-size: 10px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--blush, #E8C5B0);
  margin-bottom: 10px;
}
.timeline-title {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: 28px;
  font-weight: 300;
  color: var(--cream, #F7F2EA);
  line-height: 1.2;
  margin-bottom: 14px;
}
.timeline-node p {
  font-size: 14px;
  line-height: 1.8;
  color: rgba(250,246,240,0.6);
  max-width: 240px;
  margin: 0 auto;
}

/* ── Lineage / heritage section ── */
.product-lineage {
