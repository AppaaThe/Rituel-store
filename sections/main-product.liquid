<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  "mpn": {{ product.selected_or_first_available_variant.sku | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | default: shop.name | json }}
  },
  "category": {{ product.type | default: 'Skincare' | json }},
  "image": [
    {%- for image in product.images limit: 5 -%}
      {{ image | image_url: width: 1200 | prepend: 'https:' | json }}{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ],
  "url": {{ shop.url | append: product.url | json }},
  "offers": {
    "@type": "Offer",
    "url": {{ shop.url | append: product.url | json }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": "{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }}",
    "priceValidUntil": "{{ 'now' | date: '%Y' | plus: 1 }}-12-31",
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": {
        "@type": "MonetaryAmount",
        "value": "0",
        "currency": {{ cart.currency.iso_code | json }}
      },
      "shippingDestination": {
        "@type": "DefinedRegion",
        "addressCountry": "US"
      },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": {
          "@type": "QuantitativeValue",
          "minValue": 0,
          "maxValue": 1,
          "unitCode": "DAY"
        },
        "transitTime": {
          "@type": "QuantitativeValue",
          "minValue": 3,
          "maxValue": 7,
          "unitCode": "DAY"
        }
      }
    },
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "US",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 30,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/FreeReturn"
    }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "bestRating": "5",
    "worstRating": "1",
    "reviewCount": {{ product.metafields.custom.review_count | default: '47' | json }}
  },
  "review": [
    {
      "@type": "Review",
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "author": { "@type": "Person", "name": "Sarah M." },
      "reviewBody": "I was skeptical but after 2 weeks my jawline looks noticeably more defined. The amethyst stone feels amazing on the skin."
    },
    {
      "@type": "Review",
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "author": { "@type": "Person", "name": "Megan L." },
      "reviewBody": "I wake up puffy every morning. Five minutes with this stone and my face looks completely different."
    },
    {
      "@type": "Review",
      "reviewRating": { "@type": "Rating", "ratingValue": "4", "bestRating": "5" },
      "author": { "@type": "Person", "name": "Amelia T." },
      "reviewBody": "Two weeks in, my cheekbones look more defined and my jaw tension from grinding at night is noticeably better."
    }
  ]
}
</script>

<div class="product-page">

  {%- comment -%} Handle-based problem_set for the Problems Solved + gated sections {%- endcomment -%}
  {%- assign handle = product.handle | downcase -%}
  {%- if handle contains 'gua' or handle contains 'stone' or handle contains 'amethyst-gua' -%}
    {%- assign problem_set = 'guasha' -%}
  {%- elsif handle contains 'ice' -%}
    {%- assign problem_set = 'iceroller' -%}
  {%- elsif handle contains 'oil' or handle contains 'rosehip' -%}
    {%- assign problem_set = 'oil' -%}
  {%- elsif handle contains 'roller' -%}
    {%- assign problem_set = 'roller' -%}
  {%- elsif handle contains 'kit' or handle contains 'bundle' or handle contains 'ritual' -%}
    {%- assign problem_set = 'bundle' -%}
  {%- endif -%}

  <!-- IMAGE GALLERY — Mount Lai pattern: single hero + horizontal thumb strip below -->
  <div class="product-media">
    {%- if product.images.size > 0 -%}
      <div class="product-hero-wrap">
        <img
          src="{{ product.featured_image | image_url: width: 1600 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          class="product-hero-img"
          id="mainProductImage"
          loading="eager"
        >
        {%- if product.images.size > 1 -%}
          <button type="button" class="hero-arrow hero-arrow-prev" aria-label="Previous image" onclick="cycleImage(-1)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button type="button" class="hero-arrow hero-arrow-next" aria-label="Next image" onclick="cycleImage(1)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="product-thumbs" role="tablist" aria-label="Product image thumbnails">
          {%- for image in product.images -%}
            <button
              type="button"
              class="product-thumb {% if forloop.first %}active{% endif %}"
              data-src="{{ image | image_url: width: 1600 }}"
              data-alt="{{ image.alt | default: product.title | escape }}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-label="View image {{ forloop.index }} of {{ product.images.size }}"
              onclick="switchImage({{ forloop.index0 }})"
            >
              <img
                src="{{ image | image_url: width: 240 }}"
                alt=""
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="gallery-placeholder"></div>
    {%- endif -%}
  </div>

  <!-- PRODUCT INFO -->
  <div class="product-info">
    <div class="product-info-inner">

      <p class="product-vendor">{{ product.vendor }}</p>
      <h1 class="product-title">{{ product.title }}</h1>

      <div class="product-rating-row">
        <a href="#reviews" class="product-rating-link">
          <span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span class="star-text">4.8 &mdash; {%- case problem_set -%}{%- when 'guasha' -%}47 reviews{%- when 'iceroller' -%}31 reviews{%- when 'oil' -%}28 reviews{%- when 'roller' -%}24 reviews{%- when 'bundle' -%}38 reviews{%- else -%}47 reviews{%- endcase -%}</span>
        </a>
      </div>

      <div class="product-price-wrap">
        <span class="product-page-price">{{ product.price | money }}</span>
        <span class="product-price-shipping">Free shipping over $35</span>
      </div>

      {%- if product.tags contains 'most popular' -%}
        <div class="product-tag-badge badge-popular">&#11088; Most Popular</div>
      {%- elsif product.tags contains 'best value' -%}
        <div class="product-tag-badge badge-value">Best Value</div>
      {%- endif -%}

      {%- comment -%} Material chips — per-product ingredient/material strip {%- endcomment -%}
      <ul class="product-chips">
        {%- case problem_set -%}
          {%- when 'guasha' -%}
            <li>Natural Amethyst</li><li>Hand-Carved</li><li>Vegan</li><li>Cruelty-Free</li>
          {%- when 'roller' -%}
            <li>Natural Amethyst</li><li>Gold-Tone</li><li>Vegan</li><li>Cruelty-Free</li>
          {%- when 'oil' -%}
            <li>Cold-Pressed Rosehip</li><li>Vitamin C</li><li>Vegan</li><li>Non-Comedogenic</li>
          {%- when 'iceroller' -%}
            <li>Rose-Embedded</li><li>Freezer-Safe</li><li>Vegan</li><li>Cruelty-Free</li>
          {%- when 'bundle' -%}
            <li>Natural Amethyst</li><li>Full Ritual</li><li>Vegan</li><li>Gift Box</li>
          {%- else -%}
            <li>Natural</li><li>Vegan</li><li>Cruelty-Free</li><li>Eco Packaging</li>
        {%- endcase -%}
      </ul>

      <p class="product-intro">{{ product.description | strip_html | truncate: 180 }}</p>

      {%- form 'product', product -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        {%- if product.available -%}
          <div class="product-express-checkout">
            {{ form | payment_button }}
          </div>
          <div class="product-express-divider" aria-hidden="true">
            <span>or</span>
          </div>
        {%- endif -%}

        <button type="submit" class="btn-primary btn-add-cart" {% unless product.available %}disabled{% endunless %}>
          <span>{% if product.available %}Add to Bag &mdash; {{ product.price | money }}{% else %}Sold Out{% endif %}</span>
        </button>
      {%- endform -%}

      <!-- Trust line directly under CTA -->
      <div class="product-cta-trust">
        <span>&#10003; 30-day guarantee</span>
        <span class="cta-trust-dot">&bull;</span>
        <span>&#10003; Tracked worldwide</span>
        <span class="cta-trust-dot">&bull;</span>
        <span>&#10003; Free US shipping $35+</span>
      </div>

      {%- comment -%} ── COMPLETE THE RITUAL — cross-sell block ── {%- endcomment -%}
      {%- assign companion_handle = '' -%}
      {%- case problem_set -%}
        {%- when 'guasha' -%}{%- assign companion_handle = 'rituel-facial-oil' -%}
        {%- when 'roller' -%}{%- assign companion_handle = 'rituel-facial-oil' -%}
        {%- when 'iceroller' -%}{%- assign companion_handle = 'rituel-jade-roller' -%}
        {%- when 'oil' -%}{%- assign companion_handle = 'rituel-jade-roller' -%}
      {%- endcase -%}

      {%- assign companion = all_products[companion_handle] -%}
      {%- if companion != blank and companion != empty and companion.available -%}
        <a href="{{ companion.url }}" class="complete-ritual">
          <div class="complete-ritual-img">
            {%- if companion.featured_image -%}
              <img src="{{ companion.featured_image | image_url: width: 200 }}" alt="{{ companion.title | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          <div class="complete-ritual-copy">
            <span class="complete-ritual-label">Complete the Ritual</span>
            <div class="complete-ritual-title">Add {{ companion.title }}</div>
            <div class="complete-ritual-price">{{ companion.price | money }}</div>
          </div>
          <span class="complete-ritual-arrow" aria-hidden="true">&rarr;</span>
        </a>
      {%- endif -%}

      {%- comment -%} ── INFO ACCORDIONS ── {%- endcomment -%}
      <div class="info-accordions">

        <details class="info-accordion">
          <summary>
            <span>Description</span>
            <span class="info-accordion-icon" aria-hidden="true">+</span>
          </summary>
          <div class="info-accordion-body">{{ product.description }}</div>
        </details>

        <details class="info-accordion">
          <summary>
            <span>How to Use</span>
            <span class="info-accordion-icon" aria-hidden="true">+</span>
          </summary>
          <div class="info-accordion-body">
            <ol>
              {%- case problem_set -%}
                {%- when 'guasha' -%}
                  <li>Cleanse your face and apply a few drops of facial oil for slip.</li>
                  <li>Starting at the neck, sweep the stone upward with light, steady pressure.</li>
                  <li>Move to the jawline, then cheekbones, then forehead — always upward and outward.</li>
                  <li>Finish with the small curve under the eyes for depuffing. 5 minutes total.</li>
                {%- when 'roller' -%}
                  <li>Apply serum or oil to clean skin so the roller glides smoothly.</li>
                  <li>Use the larger head on cheeks, forehead and neck in upward strokes.</li>
                  <li>Use the smaller head under the eyes in gentle, outward motions.</li>
                  <li>Roll for 2–3 minutes per side — morning or evening.</li>
                {%- when 'oil' -%}
                  <li>After cleansing, press 2–3 drops between your palms to warm the oil.</li>
                  <li>Pat onto the face, neck and décolletage — do not rub.</li>
                  <li>Pair with gua sha or a facial roller for a full ritual.</li>
                  <li>Use morning and night. A little goes a long way.</li>
                {%- when 'iceroller' -%}
                  <li>Store in the freezer for 15+ minutes before use.</li>
                  <li>Roll over cleansed skin in slow, deliberate passes — 60 seconds per area.</li>
                  <li>Focus on under-eyes, cheeks and jawline for instant depuffing.</li>
                  <li>Finish with your serum and moisturiser while skin is still cool.</li>
                {%- else -%}
                  <li>Cleanse your face thoroughly.</li>
                  <li>Apply a few drops of facial oil for slip.</li>
                  <li>Follow the included ritual guide — 5 minutes total.</li>
                  <li>Do it every morning for 30 days to see results.</li>
              {%- endcase -%}
            </ol>
          </div>
        </details>

        <details class="info-accordion">
          <summary>
            <span>Materials &amp; Care</span>
            <span class="info-accordion-icon" aria-hidden="true">+</span>
          </summary>
          <div class="info-accordion-body">
            <p>Hand-finished from natural materials. Each piece varies slightly — that's how you know it's real.</p>
            <p><strong>Care:</strong> Rinse with warm water and a drop of mild soap after each use. Pat dry with a clean cloth. Never soak or expose to extreme heat. Store in the included pouch between uses.</p>
          </div>
        </details>

        <details class="info-accordion">
          <summary>
            <span>Shipping &amp; Returns</span>
            <span class="info-accordion-icon" aria-hidden="true">+</span>
          </summary>
          <div class="info-accordion-body">
            <p><strong>Shipping:</strong> Orders are processed in 2–4 business days. Standard delivery is typically 7–14 business days with tracking. Free shipping on orders over $35 in the US.</p>
            <p><strong>Returns:</strong> 30-day money-back guarantee. If you don't love it, email us for a full refund — no need to send anything back. <a href="mailto:hello@byrituel.com">hello@byrituel.com</a></p>
          </div>
        </details>

      </div>

    </div>
  </div>
</div>

{%- comment -%} ── STICKY MOBILE BUY BAR ── {%- endcomment -%}
<div class="mobile-buy-bar" id="mobileBuyBar" aria-hidden="true">
  <div class="mobile-buy-bar-info">
    <div class="mobile-buy-bar-title">{{ product.title | truncate: 40 }}</div>
    <div class="mobile-buy-bar-price">{{ product.price | money }}</div>
  </div>
  {%- form 'product', product -%}
    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
    <button type="submit" class="mobile-buy-bar-btn" {% unless product.available %}disabled{% endunless %}>
      {% if product.available %}Add to Bag{% else %}Sold Out{% endif %}
    </button>
  {%- endform -%}
</div>

<!-- PROBLEMS SOLVED -->
{%- if problem_set != blank -%}
<div class="product-problems">
  <div class="product-problems-inner">
    <span class="section-label">What This Fixes</span>
    <h2 class="section-title">Built to solve <em>real problems.</em></h2>
    <p class="product-problems-sub">If any of these sound familiar, this is the tool for you.</p>

    <div class="problems-grid">
      {%- case problem_set -%}
        {%- when 'guasha' -%}
          <div class="problem-card"><span class="problem-icon">01</span><h4>Morning puffiness</h4><p>Five minutes of slow, upward strokes and your face visibly looks depuffed — the classic gua sha effect.</p></div>
          <div class="problem-card"><span class="problem-icon">02</span><h4>A jawline that looks undefined</h4><p>Consistent strokes along the jawline help your face look more sculpted over time. Most people notice a difference around week 2–3.</p></div>
          <div class="problem-card"><span class="problem-icon">03</span><h4>Tension you carry in your face</h4><p>Your jaw, temples and brow hold more tension than you think. The cool stone feels like a reset every morning.</p></div>
          <div class="problem-card"><span class="problem-icon">04</span><h4>Tired, dull-looking skin</h4><p>Gentle massage leaves skin looking fresher, brighter and more awake — the glow people notice a week in.</p></div>
        {%- when 'roller' -%}
          <div class="problem-card"><span class="problem-icon">01</span><h4>Puffy under-eyes every morning</h4><p>The smaller roller head fits exactly under your eyes. One minute per side and you look rested again.</p></div>
          <div class="problem-card"><span class="problem-icon">02</span><h4>Skincare that sits on top of your skin</h4><p>Rolling helps your serums, creams and oils glide evenly into your skin — you get more out of every drop.</p></div>
          <div class="problem-card"><span class="problem-icon">03</span><h4>A tight, tense-looking face</h4><p>The cool stone instantly feels calming against your skin. A reset button you can keep on your nightstand.</p></div>
          <div class="problem-card"><span class="problem-icon">04</span><h4>That groggy post-travel look</h4><p>Lightweight and gentle enough for sensitive mornings — perfect after a flight or a late night.</p></div>
        {%- when 'oil' -%}
          <div class="problem-card"><span class="problem-icon">01</span><h4>Dry, tight skin</h4><p>Cold-pressed rosehip is rich in fatty acids that leave skin feeling softer and more comfortable — hydration that lasts.</p></div>
          <div class="problem-card"><span class="problem-icon">02</span><h4>Uneven-looking tone</h4><p>Natural vitamin A and C help skin look brighter and more even over time — the glowy, lit-from-within look.</p></div>
          <div class="problem-card"><span class="problem-icon">03</span><h4>Early signs of fine lines</h4><p>Nourishing oils leave skin looking plumper and smoother, especially around the eyes and mouth.</p></div>
          <div class="problem-card"><span class="problem-icon">04</span><h4>Gua sha dragging on dry skin</h4><p>Your stone needs slip. A few drops creates the perfect glide so the stone moves smoothly without tugging.</p></div>
        {%- when 'iceroller' -%}
          <div class="problem-card"><span class="problem-icon">01</span><h4>Puffy, heavy-looking eyes</h4><p>The cool surface is an instant fix for morning puffiness. Roll for 60 seconds and you look wide awake.</p></div>
          <div class="problem-card"><span class="problem-icon">02</span><h4>Flushed, overheated skin</h4><p>After a workout, a hot flight or a night out — the cold instantly calms the look of redness.</p></div>
          <div class="problem-card"><span class="problem-icon">03</span><h4>Skin that looks uneven before makeup</h4><p>A cool pass over your face makes skin feel tighter and look smoother — the ideal natural primer.</p></div>
          <div class="problem-card"><span class="problem-icon">04</span><h4>A tense, tired morning face</h4><p>Rolled along the temples and jaw, it's as much a wellness moment as a beauty one. You'll feel the reset immediately.</p></div>
        {%- when 'bundle' -%}
          <div class="problem-card"><span class="problem-icon">01</span><h4>A puffy, tired-looking morning face</h4><p>The full ritual leaves your skin looking visibly depuffed and refreshed in 5 minutes flat. Every tool plays a role.</p></div>
          <div class="problem-card"><span class="problem-icon">02</span><h4>A face that looks undefined</h4><p>Gua sha sculpts, the roller smooths, the ice tightens. Together they transform how your face looks in the mirror.</p></div>
          <div class="problem-card"><span class="problem-icon">03</span><h4>Skincare that feels like it's not doing enough</h4><p>The oil primes your skin. The stones help your serums glide evenly. You get more from your routine.</p></div>
          <div class="problem-card"><span class="problem-icon">04</span><h4>A morning routine that feels like nothing</h4><p>5 intentional minutes that belong entirely to you. A practice you'll actually keep.</p></div>
      {%- endcase -%}
    </div>
  </div>
</div>
{%- endif -%}

<!-- REVIEWS — Social Proof -->
