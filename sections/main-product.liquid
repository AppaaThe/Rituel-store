  font-weight: 600;
  color: var(--espresso, #2C1810);
}

.product-compare-price {
  font-size: 18px;
  color: var(--stone, #8B7355);
  text-decoration: line-through;
}

.product-save-badge {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  background: rgba(196,113,74,0.1);
  color: var(--terracotta, #C4714A);
  padding: 4px 10px;
  border-radius: 0;
}

.product-tag-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 5px 14px;
  border-radius: 0;
  margin-bottom: 16px;
}

.badge-popular { background: rgba(30,18,10,0.06); color: var(--espresso, #2C1810); }
.badge-value { background: rgba(184,112,74,0.1); color: var(--terracotta, #B8704A); }

/* First-order offer banner */
.product-offer-banner {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  background: rgba(184,112,74,0.08);
  border-left: 3px solid var(--terracotta, #B8704A);
  margin-bottom: 18px;
  font-size: 13px;
  color: var(--espresso, #1E120A);
}
.offer-icon { font-size: 16px; }
.offer-text strong { font-weight: 600; color: var(--terracotta, #B8704A); }

/* Price line with shipping hint */
.product-price-shipping {
  font-size: 12px;
  color: var(--stone, #8B7355);
  letter-spacing: 0.04em;
  margin-left: 12px;
}

/* Trust row directly under CTA */
.product-cta-trust {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10px;
  padding: 14px 4px 4px;
  font-size: 12px;
  color: var(--stone, #8B7355);
  letter-spacing: 0.02em;
  margin-bottom: 24px;
}
.product-cta-trust span { white-space: nowrap; }
.cta-trust-dot { opacity: 0.4; }

.product-description {
  font-size: 15px;
  line-height: 1.75;
  color: #5a4a3a;
  margin-bottom: 28px;
}

.product-description p { margin-bottom: 12px; }

/* CTA BUTTON */
.btn-add-cart {
  width: 100%;
  padding: 18px 32px;
  background: var(--terracotta, #B8704A);
  color: var(--cream, #FAF6F0);
  border: none;
  border-radius: 0;
  font-family: var(--sans, 'Jost', sans-serif);
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.3s;
  margin-bottom: 24px;
  position: relative;
  overflow: hidden;
}
.btn-add-cart::after {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--espresso, #2C1810);
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.23,1,0.32,1);
}
.btn-add-cart span {
  position: relative;
  z-index: 1;
}
.btn-add-cart:hover::after {
  transform: translateY(0);
}

.btn-add-cart:hover { background: var(--espresso, #2C1810); }
.btn-add-cart:disabled { opacity: 0.4; cursor: not-allowed; }

/* Trust Grid */
.product-trust-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.trust-badge {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 14px 16px;
  background: rgba(44,24,16,0.02);
  border-radius: 0;
  border: 1px solid rgba(44,24,16,0.06);
}

.trust-badge svg { color: var(--terracotta, #B8704A); flex-shrink: 0; margin-top: 2px; }
.trust-badge strong { display: block; font-size: 13px; color: var(--espresso, #2C1810); }
.trust-badge span { font-size: 11px; color: var(--stone, #8B7355); }

/* ── PROBLEMS SOLVED ── */
.product-problems {
  background: var(--cream-dark, #EFE7DB);
  padding: 100px 40px;
  margin: 0;
}
.product-problems-inner {
  max-width: 1180px;
  margin: 0 auto;
  text-align: center;
}
.product-problems .section-title {
  font-family: var(--serif);
  font-size: clamp(36px, 4.5vw, 56px);
  font-weight: 300;
  line-height: 1.1;
  margin: 18px 0 18px;
  color: var(--espresso);
}
.product-problems .section-title em { font-style: italic; color: var(--terracotta); }
.product-problems-sub {
  font-size: 16px;
  line-height: 1.7;
  color: var(--stone);
  max-width: 560px;
  margin: 0 auto 56px;
}
.problems-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2px;
  background: var(--cream);
  text-align: left;
}
.problem-card {
  background: var(--white);
  padding: 44px 40px;
  transition: transform 0.3s ease;
}
.problem-card:hover { transform: translateY(-4px); }
.problem-icon {
  display: block;
  font-family: var(--serif);
  font-size: 36px;
  font-weight: 300;
  color: var(--terracotta);
  margin-bottom: 14px;
  line-height: 1;
}
.problem-card h4 {
  font-family: var(--serif);
  font-size: 22px;
  font-weight: 400;
  color: var(--espresso);
  line-height: 1.3;
  margin: 0 0 12px;
}
.problem-card p {
  font-size: 14px;
  line-height: 1.8;
  color: var(--stone);
  margin: 0;
}
@media (max-width: 768px) {
  .product-problems { padding: 72px 20px; }
  .problems-grid { grid-template-columns: 1fr; }
  .problem-card { padding: 36px 28px; }
}

/* ── PRODUCT SECTIONS ── */
.product-section {
  padding: 80px 48px;
  max-width: 1100px;
  margin: 0 auto;
}

.product-section--dark {
  background: var(--espresso, #2C1810);
  max-width: 100%;
  text-align: center;
}

.section-title {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: clamp(28px, 3.5vw, 42px);
  font-weight: 400;
  color: var(--espresso, #2C1810);
  text-align: center;
  margin-bottom: 48px;
}

.section-title em { color: var(--terracotta, #B8704A); font-style: italic; }
.section-title--light { color: var(--cream, #FAF6F0); }
.section-title--light em { color: var(--blush, #E8C5B0); }

.section-subtitle {
  font-size: 16px;
  color: rgba(250,246,240,0.5);
  text-align: center;
  margin-top: -32px;
  margin-bottom: 48px;
}

/* Included Grid */
.included-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.included-card {
  background: white;
  padding: 32px 28px;
  border-radius: 0;
  text-align: center;
  box-shadow: 0 2px 20px rgba(44,24,16,0.06);
}

.included-icon { font-size: 32px; display: block; margin-bottom: 16px; }

.included-card h4 {
  font-family: var(--sans, 'Jost', sans-serif);
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--espresso, #2C1810);
  margin-bottom: 8px;
}

.included-card p {
  font-size: 14px;
  color: var(--stone, #8B7355);
  line-height: 1.6;
}

/* Results Grid */
.results-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  max-width: 800px;
  margin: 0 auto;
}

.result-card {
  padding: 32px 20px;
  border: 1px solid rgba(250,246,240,0.1);
  border-radius: 0;
}

.result-stat {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: 42px;
  font-weight: 300;
  color: var(--terracotta, #B8704A);
  margin-bottom: 8px;
}

.result-card p {
  font-size: 14px;
  color: rgba(250,246,240,0.6);
  line-height: 1.6;
}

/* Reviews */
.reviews-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.review-card {
  background: white;
  padding: 32px 28px;
  border-radius: 0;
  box-shadow: 0 2px 20px rgba(44,24,16,0.06);
}

.review-stars { color: #F5A623; font-size: 16px; margin-bottom: 16px; letter-spacing: 2px; }

.review-text {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: 18px;
  font-weight: 300;
  line-height: 1.6;
  color: var(--espresso, #2C1810);
  margin-bottom: 16px;
  font-style: italic;
}

.review-author {
  font-size: 13px;
  color: var(--stone, #8B7355);
}

.review-badge {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: rgba(184,112,74,0.1);
  color: var(--terracotta, #B8704A);
  padding: 2px 8px;
  border-radius: 100px;
  margin-left: 6px;
}

/* FAQ */
.product-faq {
  max-width: 700px;
  margin: 0 auto;
}

.faq-item {
  border-bottom: 1px solid rgba(44,24,16,0.08);
}

.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 20px 0;
  font-size: 16px;
  font-weight: 500;
  color: var(--espresso, #2C1810);
  background: none;
  border: 0;
  text-align: left;
  font-family: inherit;
  cursor: pointer;
  min-height: 44px;
}

.faq-question:focus-visible {
  outline: 2px solid var(--terracotta, #A15E3C);
  outline-offset: 4px;
}

.faq-question[aria-expanded="true"] .faq-toggle { transform: rotate(45deg); }

.faq-toggle {
  font-size: 24px;
  font-weight: 300;
  color: var(--terracotta, #B8704A);
  transition: transform 0.3s;
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, padding 0.3s ease;
}

.faq-item.open .faq-answer {
  max-height: 600px;
  padding-bottom: 20px;
}

.faq-answer p {
  font-size: 15px;
  color: #5a4a3a;
  line-height: 1.7;
}

/* Guarantee */
.product-section--guarantee {
  padding: 60px 48px 80px;
}

.guarantee-box {
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
  padding: 48px 40px;
  border: 2px solid rgba(184,112,74,0.15);
  border-radius: 0;
}

.guarantee-icon { color: var(--terracotta, #B8704A); margin-bottom: 20px; }

.guarantee-box h3 {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: 28px;
  font-weight: 400;
  color: var(--espresso, #2C1810);
  margin-bottom: 12px;
}

.guarantee-box p {
  font-size: 15px;
  color: var(--stone, #8B7355);
  line-height: 1.7;
}

/* ── Material Education (Product Page Inline) ── */
.product-section--material {
  background: var(--cream-dark, #EDE6D6);
  max-width: 100%;
  text-align: center;
}
.material-inline-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  max-width: 900px;
  margin: 0 auto;
}
.material-inline-card {
  background: var(--white, #FDFAF5);
  padding: 40px 28px;
  text-align: center;
  transition: background 0.3s;
}
.material-inline-card:hover {
  background: var(--cream, #F7F2EA);
}
.material-inline-num {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: 36px;
  font-weight: 300;
  color: rgba(30,18,10,0.08);
  display: block;
  margin-bottom: 16px;
  line-height: 1;
}
.material-inline-card h4 {
  font-family: var(--sans, 'Jost', sans-serif);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--espresso, #2C1810);
  margin-bottom: 10px;
}
.material-inline-card p {
  font-size: 14px;
  color: var(--stone, #8B7355);
  line-height: 1.7;
}

/* ── Press Trust (Product Page) ── */
.product-section--press {
  text-align: center;
  padding: 48px 48px;
  border-top: 1px solid rgba(30,18,10,0.06);
}
.product-section--press .press-label {
  display: block;
  font-size: 9px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--stone, #8B7355);
  margin-bottom: 28px;
}
.product-press-logos {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48px;
  flex-wrap: wrap;
}
.product-press-name {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: 22px;
  font-weight: 400;
  letter-spacing: 0.12em;
  color: var(--espresso, #1E120A);
  opacity: 0.2;
  transition: opacity 0.3s;
}
.product-press-name:hover {
  opacity: 0.5;
}

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .product-page { grid-template-columns: 1fr; }
  .product-media {
    position: relative;
    top: 0;
    padding: 24px;
    flex-direction: column-reverse;
  }
  .product-gallery {
    flex-direction: row;
    width: 100%;
    overflow-x: auto;
  }
  .product-gallery { gap: 12px; }
  .product-gallery-thumb { width: 64px; height: 64px; flex-shrink: 0; }
  .product-info { padding: 24px; }
  .product-trust-grid { grid-template-columns: 1fr; }
  .included-grid { grid-template-columns: 1fr; }
  .results-grid { grid-template-columns: 1fr; }
  .reviews-grid { grid-template-columns: 1fr; }
  .product-section { padding: 56px 24px; }
  .material-inline-grid { grid-template-columns: 1fr; }
  .product-press-logos { gap: 28px; }
  .product-press-name { font-size: 18px; }
}
</style>

<script>
function switchImage(index) {
  var thumbs = document.querySelectorAll('.product-gallery-thumb');
  var main = document.getElementById('mainProductImage');
  if (!thumbs.length || !main) return;
  if (index < 0) index = thumbs.length - 1;
  if (index >= thumbs.length) index = 0;
  thumbs.forEach(function(t) {
    t.classList.remove('active');
    t.setAttribute('aria-selected', 'false');
  });
  var active = thumbs[index];
  active.classList.add('active');
  active.setAttribute('aria-selected', 'true');
  var img = active.querySelector('img');
  if (img) {
    main.src = img.src;
    main.alt = img.alt || '';
  }
  main.dataset.currentIndex = index;
  var counter = document.getElementById('galleryCounter');
  if (counter) counter.textContent = (index + 1) + ' / ' + thumbs.length;
}

function cycleImage(delta) {
  var main = document.getElementById('mainProductImage');
  if (!main) return;
  var current = parseInt(main.dataset.currentIndex || '0', 10);
  switchImage(current + delta);
}

document.addEventListener('keydown', function(e) {
  if (e.target.closest('input, textarea, select')) return;
  if (!document.getElementById('mainProductImage')) return;
  if (e.key === 'ArrowLeft') cycleImage(-1);
  if (e.key === 'ArrowRight') cycleImage(1);
});

(function initGalleryIndex() {
  var main = document.getElementById('mainProductImage');
  if (main) main.dataset.currentIndex = '0';
})();

function toggleFaq(btn) {
  var faqItem = btn.closest('.faq-item');
  if (!faqItem) return;
  var isOpen = faqItem.classList.toggle('open');
  btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
}
</script>

