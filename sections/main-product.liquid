/* Reviews */
.reviews-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.review-card {
  background: white;
  padding: 32px 28px;
  border-radius: 0;
  box-shadow: 0 2px 20px rgba(44,24,16,0.06);
}

.review-stars { color: #D4956E; font-size: 16px; margin-bottom: 16px; letter-spacing: 2px; }

.review-text {
  font-family: var(--serif, 'Cormorant Garamond', serif);
