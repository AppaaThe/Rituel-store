}

.product-lineage-footnote {
  margin: 48px auto 0;
  max-width: 620px;
  text-align: center;
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: clamp(17px, 1.3vw, 20px);
  font-style: italic;
  line-height: 1.6;
  color: var(--stone, #8B7355);
