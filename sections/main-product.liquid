  font-size: clamp(38px, 4.5vw, 60px);
  font-weight: 300;
  line-height: 1.08;
  letter-spacing: -0.005em;
  color: var(--espresso, #1E120A);
  margin: 18px 0 24px;
}
.product-lineage-title em {
  font-style: italic;
  color: var(--terracotta, #B8704A);
}
.product-lineage-lede {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: clamp(17px, 1.3vw, 20px);
  line-height: 1.7;
  color: var(--stone, #8B7355);
  font-style: italic;
