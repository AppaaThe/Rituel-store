  .product-lineage-grid { grid-template-columns: 1fr; }
  .lineage-card { padding: 44px 32px 40px; }
  .lineage-num { font-size: 40px; margin-bottom: 18px; }
  .product-lineage-stats { grid-template-columns: repeat(2, 1fr); margin-top: 48px; }
  .lineage-stat { padding: 28px 14px; }
