  .material-inline-grid { grid-template-columns: 1fr; }
  .product-press-logos { gap: 28px; }
  .product-press-name { font-size: 18px; }
}
</style>

<script>
/* Gallery: single hero swaps when a thumbnail is clicked or arrows pressed */
window.productGalleryIndex = 0;

function switchImage(index) {
  var thumbs = document.querySelectorAll('.product-thumb');
  var main = document.getElementById('mainProductImage');
  if (!thumbs.length || !main) return;

  var total = thumbs.length;
  index = ((index % total) + total) % total;

  for (var i = 0; i < thumbs.length; i++) {
    thumbs[i].classList.remove('active');
    thumbs[i].setAttribute('aria-selected', 'false');
  }

  var active = thumbs[index];
  active.classList.add('active');
  active.setAttribute('aria-selected', 'true');

  var src = active.getAttribute('data-src');
  if (!src) {
    var innerImg = active.querySelector('img');
    if (innerImg) src = innerImg.src;
  }
  var alt = active.getAttribute('data-alt') || main.alt || '';

  if (src) {
    main.classList.add('swapping');
    main.removeAttribute('srcset');
    main.removeAttribute('sizes');
    main.src = src;
    main.alt = alt;
    setTimeout(function() {
      main.classList.remove('swapping');
    }, 200);
  }

  window.productGalleryIndex = index;
  main.dataset.currentIndex = index;

  if (active.scrollIntoView) {
    active.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  }
}

function cycleImage(delta) {
  switchImage(window.productGalleryIndex + delta);
}

document.addEventListener('keydown', function(e) {
  if (e.target.closest('input, textarea, select')) return;
  if (!document.getElementById('mainProductImage')) return;
  if (e.key === 'ArrowLeft') cycleImage(-1);
  if (e.key === 'ArrowRight') cycleImage(1);
});

(function initGalleryIndex() {
  var main = document.getElementById('mainProductImage');
  if (main) main.dataset.currentIndex = '0';
})();

/* Scroll-reveal: fade + slide-up sections as they enter viewport */
(function initScrollReveal() {
  var targets = document.querySelectorAll('.product-problems, .product-section, .product-ritual, .results-timeline, .timeline-node, .problem-card, .material-inline-card, .product-lineage, .lineage-card');
  if (!targets.length || typeof IntersectionObserver === 'undefined') return;
  targets.forEach(function(el) { el.classList.add('reveal'); });
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
  targets.forEach(function(el) { io.observe(el); });
})();

/* Sticky mobile buy bar — appears once main Add-to-Bag CTA scrolls off screen */
(function initMobileBuyBar() {
  var bar = document.getElementById('mobileBuyBar');
  var cta = document.querySelector('.btn-add-cart');
  if (!bar || !cta) return;
  function onScroll() {
    if (window.innerWidth > 768) { bar.classList.remove('visible'); return; }
    var rect = cta.getBoundingClientRect();
    if (rect.bottom < 0) bar.classList.add('visible');
    else bar.classList.remove('visible');
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll);
  onScroll();
})();

function toggleFaq(btn) {
  var faqItem = btn.closest('.faq-item');
  if (!faqItem) return;
  var isOpen = faqItem.classList.toggle('open');
  btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
}
</script>

