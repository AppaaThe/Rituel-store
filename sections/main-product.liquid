  justify-content: space-between;
  align-items: center;
  padding: 20px 0;
  font-size: 16px;
  font-weight: 500;
  color: var(--espresso, #2C1810);
}

.faq-toggle {
  font-size: 24px;
  font-weight: 300;
  color: var(--terracotta, #B8704A);
  transition: transform 0.3s;
}

.faq-item.open .faq-toggle { transform: rotate(45deg); }

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, padding 0.3s ease;
}

.faq-item.open .faq-answer {
  max-height: 200px;
  padding-bottom: 20px;
}

.faq-answer p {
  font-size: 15px;
  color: #5a4a3a;
  line-height: 1.7;
}

/* Guarantee */
.product-section--guarantee {
  padding: 60px 48px 80px;
}

.guarantee-box {
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
  padding: 48px 40px;
  border: 2px solid rgba(184,112,74,0.15);
  border-radius: 0;
}

.guarantee-icon { color: var(--terracotta, #B8704A); margin-bottom: 20px; }

.guarantee-box h3 {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: 28px;
  font-weight: 400;
  color: var(--espresso, #2C1810);
  margin-bottom: 12px;
}

.guarantee-box p {
  font-size: 15px;
  color: var(--stone, #8B7355);
  line-height: 1.7;
}

/* ── Material Education (Product Page Inline) ── */
.product-section--material {
  background: var(--cream-dark, #EDE6D6);
  max-width: 100%;
  text-align: center;
}
.material-inline-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  max-width: 900px;
  margin: 0 auto;
}
.material-inline-card {
  background: var(--white, #FDFAF5);
  padding: 40px 28px;
  text-align: center;
  transition: background 0.3s;
}
.material-inline-card:hover {
  background: var(--cream, #F7F2EA);
}
.material-inline-num {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: 36px;
  font-weight: 300;
  color: rgba(30,18,10,0.08);
  display: block;
  margin-bottom: 16px;
  line-height: 1;
}
.material-inline-card h4 {
  font-family: var(--sans, 'Jost', sans-serif);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--espresso, #2C1810);
  margin-bottom: 10px;
}
.material-inline-card p {
  font-size: 14px;
  color: var(--stone, #8B7355);
  line-height: 1.7;
}

/* ── Press Trust (Product Page) ── */
.product-section--press {
  text-align: center;
  padding: 48px 48px;
  border-top: 1px solid rgba(30,18,10,0.06);
}
.product-section--press .press-label {
  display: block;
  font-size: 9px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--stone, #8B7355);
  margin-bottom: 28px;
}
.product-press-logos {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48px;
  flex-wrap: wrap;
}
.product-press-name {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: 22px;
  font-weight: 400;
  letter-spacing: 0.12em;
  color: var(--espresso, #1E120A);
  opacity: 0.2;
  transition: opacity 0.3s;
}
.product-press-name:hover {
  opacity: 0.5;
}

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .product-page { grid-template-columns: 1fr; }
  .product-media {
    position: relative;
    top: 0;
    padding: 24px;
    flex-direction: column-reverse;
  }
  .product-gallery {
    flex-direction: row;
    width: 100%;
    overflow-x: auto;
  }
  .product-gallery-img { width: 60px; height: 60px; }
  .product-info { padding: 24px; }
  .product-trust-grid { grid-template-columns: 1fr; }
  .included-grid { grid-template-columns: 1fr; }
  .results-grid { grid-template-columns: 1fr; }
  .reviews-grid { grid-template-columns: 1fr; }
  .product-section { padding: 56px 24px; }
  .material-inline-grid { grid-template-columns: 1fr; }
  .product-press-logos { gap: 28px; }
  .product-press-name { font-size: 18px; }
}
</style>

<script>
function switchImage(index) {
  var thumbs = document.querySelectorAll('.product-gallery-img');
  var main = document.getElementById('mainProductImage');
  thumbs.forEach(function(t) { t.classList.remove('active'); });
  thumbs[index].classList.add('active');
  main.src = thumbs[index].src;
  main.alt = thumbs[index].alt;
}

function toggleFaq(item) {
  item.classList.toggle('open');
}
</script>

{% schema %}
{
  "name": "Product",
  "presets": [{ "name": "Product" }]
}
{% endschema %}
