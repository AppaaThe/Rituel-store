  border-bottom: 1px solid rgba(30,18,10,0.08);
}
.lineage-stat {
  background: var(--cream, #F7F2EA);
  padding: 38px 20px;
  text-align: center;
  transition: background 0.3s;
}
.lineage-stat:hover {
