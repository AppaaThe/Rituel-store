      <span class="reviews-big-rating">4.8</span>
      <div class="reviews-star-display">
        <span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span class="reviews-count">Based on {%- case problem_set -%}{%- when 'guasha' -%}47{%- when 'iceroller' -%}31{%- when 'oil' -%}28{%- when 'roller' -%}24{%- when 'bundle' -%}38{%- else -%}47{%- endcase -%} reviews</span>
      </div>
    </div>
  </div>

  <div class="reviews-grid">
    {%- case problem_set -%}
    {%- when 'guasha' -%}
