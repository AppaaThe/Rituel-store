}
.lineage-stat-num {
  font-family: var(--serif, 'Cormorant Garamond', serif);
  font-size: clamp(26px, 2.4vw, 36px);
  font-weight: 300;
  line-height: 1.1;
  color: var(--terracotta, #B8704A);
  margin-bottom: 10px;
  letter-spacing: -0.005em;
}
.lineage-stat-label {
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--stone, #8B7355);
