<section class="concern-section">
  <div class="concern-inner">

    <div class="concern-header reveal">
      <span class="section-label">Shop by Concern</span>
      <h2 class="section-title">What does your skin <span class="section-title-accent">need?</span></h2>
    </div>

    <div class="concern-grid">

      <a href="/products/rituel-ice-roller" class="concern-card reveal">
        <div class="concern-image">
          <img src="{{ 'br-card-ice-lifestyle.webp' | asset_url }}" alt="" loading="lazy" width="400" height="500">
        </div>
        <div class="concern-body">
          <span class="concern-eyebrow">Puffiness</span>
          <h3 class="concern-title">De-puff</h3>
          <p class="concern-desc">Wake up puffy? Drain overnight fluid and look sculpted by breakfast.</p>
          <span class="concern-link">Ice Roller <span class="arrow" aria-hidden="true">&rarr;</span></span>
        </div>
      </a>

      <a href="/products/amethyst-gua-sha" class="concern-card reveal reveal-delay-1">
        <div class="concern-image">
          <img src="{{ 'br-card-guasha-lifestyle.webp' | asset_url }}" alt="" loading="lazy" width="400" height="500">
        </div>
        <div class="concern-body">
          <span class="concern-eyebrow">Definition</span>
          <h3 class="concern-title">Sculpt &amp; define</h3>
          <p class="concern-desc">Sharpen the jawline and lift cheekbones. The five-minute face workout.</p>
          <span class="concern-link">Amethyst Gua Sha <span class="arrow" aria-hidden="true">&rarr;</span></span>
        </div>
      </a>

      <a href="/products/rituel-full-ritual" class="concern-card reveal reveal-delay-2">
        <div class="concern-image">
          <img src="{{ 'br-prod-lifestyle-use.webp' | asset_url }}" alt="" loading="lazy" width="400" height="500">
        </div>
        <div class="concern-body">
          <span class="concern-eyebrow">Radiance</span>
          <h3 class="concern-title">Glow</h3>
          <p class="concern-desc">Boost circulation for that lit-from-within look &mdash; no filter required.</p>
          <span class="concern-link">Full Ritual Set <span class="arrow" aria-hidden="true">&rarr;</span></span>
        </div>
      </a>

      <a href="/products/rituel-amethyst-roller" class="concern-card reveal reveal-delay-3">
        <div class="concern-image">
          <img src="{{ 'br-card-roller-lifestyle.webp' | asset_url }}" alt="" loading="lazy" width="400" height="500">
        </div>
        <div class="concern-body">
          <span class="concern-eyebrow">Tension</span>
          <h3 class="concern-title">Soothe &amp; calm</h3>
          <p class="concern-desc">Release jaw tightness and relax facial muscles. The end-of-day unwind.</p>
          <span class="concern-link">Amethyst Roller <span class="arrow" aria-hidden="true">&rarr;</span></span>
        </div>
      </a>

    </div>
  </div>
</section>

<style>
  .concern-section {
    padding: 112px 80px;
    background: var(--cream, #F7F2EA);
  }
  .concern-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .concern-header {
    text-align: center;
    margin-bottom: 64px;
  }
  .concern-header .section-label {
    display: inline-block;
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--terracotta, #B8704A);
    margin-bottom: 18px;
  }
  .concern-header .section-title {
    font-family: var(--serif), Georgia, serif;
    font-weight: 400;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.1;
    color: var(--espresso, #1E120A);
    margin: 0;
  }
  .section-title-accent {
    color: var(--terracotta, #B8704A);
  }

  .concern-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .concern-card {
    display: grid;
    grid-template-columns: 5fr 7fr;
    background: var(--white, #FDFAF5);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    border-radius: 2px;
    position: relative;
    transition: box-shadow 0.35s ease, transform 0.35s ease;
  }
  .concern-card:hover,
  .concern-card:focus-visible {
    box-shadow: 0 18px 40px -28px rgba(30, 18, 10, 0.28);
    transform: translateY(-2px);
  }
  .concern-card:focus-visible {
    outline: 2px solid var(--terracotta, #B8704A);
    outline-offset: 3px;
  }

  .concern-image {
    overflow: hidden;
    background: var(--cream-dark, #EDE6D6);
    aspect-ratio: 4 / 5;
    min-height: 100%;
  }
  .concern-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .concern-card:hover .concern-image img,
  .concern-card:focus-visible .concern-image img {
    transform: scale(1.04);
  }

  .concern-body {
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .concern-eyebrow {
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--terracotta, #B8704A);
    margin-bottom: 14px;
  }
  .concern-title {
    font-family: var(--serif), Georgia, serif;
    font-weight: 400;
    font-size: clamp(24px, 2.6vw, 30px);
    line-height: 1.15;
    color: var(--espresso, #1E120A);
    margin: 0 0 14px;
  }
  .concern-desc {
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 14px;
    line-height: 1.65;
    color: var(--stone, #6B5A40);
    margin: 0 0 24px;
    max-width: 32ch;
  }
  .concern-link {
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--espresso, #1E120A);
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .concern-link .arrow {
    display: inline-block;
    transition: transform 0.3s ease;
    color: var(--terracotta, #B8704A);
  }
  .concern-card:hover .concern-link .arrow,
  .concern-card:focus-visible .concern-link .arrow {
    transform: translateX(4px);
  }

  @media (max-width: 900px) {
    .concern-section {
      padding: 72px 24px;
    }
    .concern-header {
      margin-bottom: 40px;
    }
    .concern-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .concern-card {
      grid-template-columns: 4fr 6fr;
    }
    .concern-body {
      padding: 24px 22px;
    }
    .concern-desc {
      margin-bottom: 18px;
    }
  }

  @media (max-width: 520px) {
    .concern-card {
      grid-template-columns: 1fr;
    }
    .concern-image {
      aspect-ratio: 5 / 3;
    }
    .concern-body {
      padding: 26px 24px 30px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .concern-card,
    .concern-image img,
    .concern-link .arrow {
      transition: none;
    }
    .concern-card:hover,
    .concern-card:focus-visible {
      transform: none;
    }
    .concern-card:hover .concern-image img,
    .concern-card:focus-visible .concern-image img {
      transform: none;
    }
    .concern-card:hover .concern-link .arrow,
    .concern-card:focus-visible .concern-link .arrow {
      transform: none;
    }
  }
</style>

{% schema %}
{
  "name": "Shop by Concern",
  "presets": [{ "name": "Shop by Concern" }]
}
{% endschema %}
