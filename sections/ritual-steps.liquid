<section class="ritual-section" id="ritual">
  <div class="ritual-inner">

    <div class="ritual-header reveal">
      <div class="ritual-header-title">
        <span class="section-label">How it works</span>
        <h2 class="ritual-title">The five-minute<br><span class="ritual-title-accent">morning ritual.</span></h2>
      </div>
      <p class="ritual-subtitle"><strong>Three steps.</strong> Visible change from the <strong>first morning</strong>. For women who <strong>refuse to spend an hour</strong> getting ready.</p>
    </div>

    <div class="ritual-steps">

      <article class="ritual-step reveal">
        <div class="ritual-step-img">
          <img src="{{ 'br-card-oil-lifestyle.webp' | asset_url }}" alt="Applying rosehip oil as the first step of the morning ritual" loading="lazy" width="400" height="300">
        </div>
        <span class="ritual-step-bg-num" aria-hidden="true">01</span>
        <div class="ritual-step-inner">
          <div class="ritual-step-top">
            <span class="ritual-step-num" aria-hidden="true">01</span>
            <span class="ritual-step-time">60 sec</span>
          </div>
          <h3 class="ritual-step-title">Oil &amp; prep</h3>
          <p class="ritual-step-desc"><strong>A few drops</strong> of rosehip oil on clean skin. The oil creates <strong>the glide</strong> &mdash; the stone should <strong>never drag</strong>.</p>
        </div>
      </article>

      <article class="ritual-step reveal reveal-delay-1">
        <div class="ritual-step-img">
          <img src="{{ 'br-card-guasha-lifestyle.webp' | asset_url }}" alt="Sculpting along the jawline with the amethyst gua sha" loading="lazy" width="400" height="300">
        </div>
        <span class="ritual-step-bg-num" aria-hidden="true">02</span>
        <div class="ritual-step-inner">
          <div class="ritual-step-top">
            <span class="ritual-step-num" aria-hidden="true">02</span>
            <span class="ritual-step-time">3 min</span>
          </div>
          <h3 class="ritual-step-title">Sculpt</h3>
          <p class="ritual-step-desc">Sweep <strong>upward and outward</strong> along the jawline, cheekbones, and forehead. <strong>Always upward.</strong> Always <strong>toward the ears</strong>. <strong>Gentle pressure.</strong></p>
        </div>
      </article>

      <article class="ritual-step reveal reveal-delay-2">
        <div class="ritual-step-img">
          <img src="{{ 'br-card-ice-lifestyle.webp' | asset_url }}" alt="Finishing the ritual with a chilled ice roller" loading="lazy" width="400" height="300">
        </div>
        <span class="ritual-step-bg-num" aria-hidden="true">03</span>
        <div class="ritual-step-inner">
          <div class="ritual-step-top">
            <span class="ritual-step-num" aria-hidden="true">03</span>
            <span class="ritual-step-time">90 sec</span>
          </div>
          <h3 class="ritual-step-title">Ice &amp; seal</h3>
          <p class="ritual-step-desc">Roll the chilled ice roller from the <strong>centre of the face outward</strong>. <strong>Skin tightens</strong>, pores look refined, <strong>redness fades</strong>. You look like you <strong>slept ten hours</strong>.</p>
        </div>
      </article>

    </div>

    <div class="ritual-total reveal">
      <div class="ritual-total-inner">
        <div class="ritual-total-left">
          <span class="ritual-total-label">Total time</span>
          <span class="ritual-total-num">5<span class="ritual-total-unit">min</span></span>
        </div>
        <div class="ritual-total-divider" aria-hidden="true"></div>
        <div class="ritual-total-right">
          <span class="ritual-total-tag">Every. Single. Morning.</span>
          <span class="ritual-total-sub">That&rsquo;s less time than brewing coffee.</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .ritual-section {
    background: var(--cream, #F7F2EA);
    padding: var(--space-section-y) var(--space-section-x) 0;
  }
  .ritual-inner {
    max-width: 1300px;
    margin: 0 auto;
  }

  .ritual-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 80px;
    align-items: end;
    margin-bottom: 72px;
  }
  .ritual-header-title {
    display: flex;
    flex-direction: column;
  }
  .ritual-header .section-label {
    display: inline-block;
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--terracotta, #B8704A);
    margin-bottom: 18px;
  }
  .ritual-title {
    font-family: var(--serif), Georgia, serif;
    font-weight: 400;
    font-size: clamp(40px, 5vw, 56px);
    line-height: 1.08;
    color: var(--espresso, #1E120A);
    margin: 0;
  }
  .ritual-title-accent {
    color: var(--terracotta, #B8704A);
  }
  .ritual-subtitle {
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 14px;
    line-height: 1.75;
    color: var(--stone, #6B5A40);
    max-width: 420px;
    padding-bottom: 8px;
    margin: 0;
  }

  .ritual-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-bottom: 2px;
  }
  .ritual-step {
    position: relative;
    overflow: hidden;
    background: var(--white, #FDFAF5);
    display: flex;
    flex-direction: column;
  }
  .ritual-step-img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--cream-dark, #EDE6D6);
  }
  .ritual-step-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ritual-step-bg-num {
    font-family: var(--serif), Georgia, serif;
    font-size: 200px;
    color: var(--espresso, #1E120A);
    opacity: 0.045;
    position: absolute;
    top: -20px;
    right: -20px;
    line-height: 1;
    pointer-events: none;
  }
  .ritual-step-inner {
    position: relative;
    padding: 48px 36px 44px;
    z-index: 1;
  }
  .ritual-step-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 24px;
  }
  .ritual-step-num {
    font-family: var(--serif), Georgia, serif;
    font-size: 42px;
    color: var(--terracotta, #B8704A);
    line-height: 1;
  }
  .ritual-step-time {
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--stone, #6B5A40);
    border: 1px solid var(--cream-dark, #EDE6D6);
    padding: 5px 12px;
    border-radius: 20px;
  }
  .ritual-step-title {
    font-family: var(--serif), Georgia, serif;
    font-weight: 400;
    font-size: clamp(24px, 2.4vw, 28px);
    margin: 0 0 14px;
    color: var(--espresso, #1E120A);
    line-height: 1.2;
  }
  .ritual-step-desc {
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 14px;
    line-height: 1.75;
    color: var(--stone, #6B5A40);
    margin: 0;
    max-width: 42ch;
  }

  .ritual-total {
    background: var(--espresso, #1E120A);
    padding: 48px 80px;
    margin: 0 -80px;
  }
  .ritual-total-inner {
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 48px;
    flex-wrap: wrap;
  }
  .ritual-total-left {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-shrink: 0;
  }
  .ritual-total-label {
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(247, 242, 234, 0.55);
  }
  .ritual-total-num {
    font-family: var(--serif), Georgia, serif;
    font-size: clamp(56px, 7vw, 72px);
    color: var(--terracotta, #B8704A);
    line-height: 1;
  }
  .ritual-total-unit {
    font-size: 0.34em;
    margin-left: 6px;
    color: var(--blush, #E8C5B0);
  }
  .ritual-total-divider {
    width: 1px;
    height: 48px;
    background: rgba(247, 242, 234, 0.14);
    flex-shrink: 0;
  }
  .ritual-total-right {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .ritual-total-tag {
    font-family: var(--serif), Georgia, serif;
    font-size: clamp(20px, 2vw, 24px);
    color: var(--blush, #E8C5B0);
    letter-spacing: 0.02em;
    line-height: 1.2;
  }
  .ritual-total-sub {
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 13px;
    color: rgba(247, 242, 234, 0.6);
    letter-spacing: 0.01em;
    line-height: 1.5;
  }

  @media (max-width: 1024px) {
    .ritual-header {
      grid-template-columns: 1fr;
      gap: 20px;
      align-items: start;
      margin-bottom: 40px;
    }
    .ritual-subtitle {
      padding-bottom: 0;
    }
    .ritual-steps {
      grid-template-columns: 1fr;
    }
    .ritual-step-inner {
      padding: 36px 28px 36px;
    }
    .ritual-step-bg-num {
      font-size: 140px;
    }
    .ritual-total {
      padding: 40px 24px;
      margin: 0 -24px;
    }
    .ritual-total-inner {
      gap: 24px;
    }
    .ritual-total-divider {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "Ritual Steps",
  "presets": [{ "name": "Ritual Steps" }]
}
{% endschema %}
