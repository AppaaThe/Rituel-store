<div style="background: var(--cream);">
  <div class="section" id="ritual">
    <div class="section-header">
      <div>
        <span class="section-label reveal">How It Works</span>
        <h2 class="section-title reveal reveal-delay-1">The 5-Minute<br><em>Morning Ritual</em></h2>
      </div>
      <p class="section-desc reveal reveal-delay-2">Three simple steps. Five minutes. Visible results from day one. Used by women across 40 countries who refuse to spend an hour getting ready.</p>
    </div>
    <div class="steps-grid">
      <div class="step-card reveal">
        <div class="step-number">01</div>
        <h3 class="step-title">Cleanse & Prep</h3>
        <p class="step-desc">Apply a few drops of facial oil to clean skin. The oil creates the perfect glide for your gua sha — never drag on dry skin.</p>
        <span class="step-time">60 seconds</span>
      </div>
      <div class="step-card reveal reveal-delay-1">
        <div class="step-number">02</div>
        <h3 class="step-title">Sculpt with Gua Sha</h3>
        <p class="step-desc">Sweep upward and outward along your jawline, cheekbones, and forehead. Gentle pressure, always upward. Always toward your ears.</p>
        <span class="step-time">3 minutes</span>
      </div>
      <div class="step-card reveal reveal-delay-2">
        <div class="step-number">03</div>
        <h3 class="step-title">Depuff with Ice</h3>
        <p class="step-desc">Roll the chilled ice roller over your face to lock in results, reduce redness, and wake up your skin. You'll look like you slept 10 hours.</p>
        <span class="step-time">90 seconds</span>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Ritual Steps",
  "presets": [{ "name": "Ritual Steps" }]
}
{% endschema %}
