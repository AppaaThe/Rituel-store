<div class="ritual-section" id="ritual">
  <div class="ritual-inner">

    <div class="ritual-header">
      <span class="section-label reveal">How It Works</span>
      <h2 class="ritual-title reveal reveal-delay-1">The 5-Minute<br><em>Morning Ritual</em></h2>
      <p class="ritual-subtitle reveal reveal-delay-2">Three steps. Visible results from day one. Used every morning by women who refuse to spend an hour getting ready.</p>
    </div>

    <div class="ritual-steps">

      <div class="ritual-step reveal">
        <div class="ritual-step-img">
          <img src="https://raw.githubusercontent.com/AppaaThe/Rituel-store/main/product-images/nbp-rosehip-oil-lifestyle.png" alt="Apply rosehip oil to prep skin for gua sha" loading="lazy">
        </div>
        <div class="ritual-step-bg-num">01</div>
        <div class="ritual-step-inner">
          <div class="ritual-step-top">
            <span class="ritual-step-num">01</span>
            <span class="ritual-step-time">60 sec</span>
          </div>
          <h3 class="ritual-step-title">Oil &amp; Prep</h3>
          <p class="ritual-step-desc">Apply a few drops of rosehip oil to clean skin. The oil creates the perfect glide — the stone should never drag.</p>
          <div class="ritual-step-line"></div>
        </div>
      </div>

      <div class="ritual-step reveal reveal-delay-1">
        <div class="ritual-step-img">
          <img src="https://raw.githubusercontent.com/AppaaThe/Rituel-store/main/product-images/nbp-guasha-lifestyle.png" alt="Sculpting jawline with amethyst gua sha stone" loading="lazy">
        </div>
        <div class="ritual-step-bg-num">02</div>
        <div class="ritual-step-inner">
          <div class="ritual-step-top">
            <span class="ritual-step-num">02</span>
            <span class="ritual-step-time">3 min</span>
          </div>
          <h3 class="ritual-step-title">Sculpt</h3>
          <p class="ritual-step-desc">Sweep upward and outward along your jawline, cheekbones, forehead. Always upward. Always toward your ears. Gentle pressure.</p>
          <div class="ritual-step-line"></div>
        </div>
      </div>

      <div class="ritual-step reveal reveal-delay-2">
        <div class="ritual-step-img">
          <img src="https://raw.githubusercontent.com/AppaaThe/Rituel-store/main/product-images/nbp-ice-roller-lifestyle.png" alt="Finishing the ritual with ice roller" loading="lazy">
        </div>
        <div class="ritual-step-bg-num">03</div>
        <div class="ritual-step-inner">
          <div class="ritual-step-top">
            <span class="ritual-step-num">03</span>
            <span class="ritual-step-time">90 sec</span>
          </div>
          <h3 class="ritual-step-title">Ice &amp; Seal</h3>
          <p class="ritual-step-desc">Roll the chilled ice roller from the centre of your face outward. Pores close. Redness fades. You look like you slept 10 hours.</p>
          <div class="ritual-step-line"></div>
        </div>
      </div>

    </div>

    <div class="ritual-total reveal">
      <div class="ritual-total-inner">
        <div class="ritual-total-left">
          <span class="ritual-total-label">Total time</span>
          <span class="ritual-total-num">5<span class="ritual-total-unit">min</span></span>
        </div>
        <div class="ritual-total-divider"></div>
        <div class="ritual-total-right">
          <span class="ritual-total-tag">Every. Single. Morning.</span>
          <span class="ritual-total-sub">That's less time than brewing coffee.</span>
        </div>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Ritual Steps",
  "presets": [{ "name": "Ritual Steps" }]
}
{% endschema %}
