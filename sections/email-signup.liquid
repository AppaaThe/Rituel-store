<section class="signup-section" id="signup">
  <div class="signup-inner">
    <span class="signup-label reveal">Join the ritual</span>
    <p class="signup-discount reveal reveal-delay-1">15% off</p>
    <h2 class="signup-subhead reveal reveal-delay-2">your first ritual.</h2>
    <p class="signup-desc reveal reveal-delay-3">Plus the free <strong>BY RITUEL Morning Ritual Guide</strong> &mdash; exactly how to use each tool, in what order. Sent straight to your inbox.</p>
    <div class="signup-form reveal reveal-delay-3">
      <div class="klaviyo-form-TpBtCX"></div>
    </div>
    <p class="signup-note">No spam. Just the ritual. Unsubscribe anytime.</p>
  </div>
</section>

<style>
  .signup-section {
    position: relative;
    overflow: hidden;
    padding: var(--space-section-y) var(--space-section-x);
    text-align: center;
    background: linear-gradient(135deg, var(--terracotta, #B8704A) 0%, var(--espresso, #1E120A) 100%);
    color: var(--cream, #F7F2EA);
  }
  .signup-section::before {
    content: "RITUEL";
    position: absolute;
    font-family: var(--serif), Georgia, serif;
    font-size: clamp(180px, 30vw, 320px);
    color: rgba(247, 242, 234, 0.05);
    letter-spacing: 0.3em;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    pointer-events: none;
    line-height: 1;
  }

  .signup-inner {
    max-width: 560px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .signup-label {
    display: inline-block;
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 12px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--blush, #E8C5B0);
    margin-bottom: 24px;
  }

  /* THE DISCOUNT — dominant red display element */
  .signup-discount {
    font-family: var(--serif), Georgia, serif;
    font-weight: 500;
    font-size: clamp(80px, 13vw, 168px);
    line-height: 0.92;
    letter-spacing: -0.035em;
    color: #FF3B1F;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.25);
    margin: 0 0 12px;
  }

  .signup-subhead {
    font-family: var(--serif), Georgia, serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(28px, 3.6vw, 44px);
    line-height: 1.1;
    color: var(--cream, #F7F2EA);
    margin: 0 0 28px;
  }

  .signup-desc {
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 15px;
    line-height: 1.7;
    color: rgba(247, 242, 234, 0.92);
    margin: 0 0 40px;
    max-width: 48ch;
    margin-left: auto;
    margin-right: auto;
  }

  .signup-form {
    margin-bottom: 20px;
  }

  .signup-note {
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 12px;
    color: rgba(247, 242, 234, 0.82);
    letter-spacing: 0.01em;
    margin: 0;
  }

  @media (max-width: 640px) {
    .signup-section::before {
      font-size: 180px;
    }
    .signup-discount {
      font-size: clamp(72px, 22vw, 120px);
    }
    .signup-subhead {
      font-size: clamp(22px, 6vw, 32px);
    }
  }
</style>

{% schema %}
{
  "name": "Email Signup",
  "presets": [{ "name": "Email Signup" }]
}
{% endschema %}
