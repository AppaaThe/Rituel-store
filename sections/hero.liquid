<style>
/* ── HERO V3: Editorial Lifestyle + Floating Product Card ── */
.hero-v3 {
  position: relative;
  min-height: 85vh;
  display: flex;
  flex-direction: column;
}

/* Background */
.hero-v3-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero-v3-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: 70% 50%;
}
.hero-v3-bg-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(95deg, rgba(30,18,10,0.88) 0%, rgba(30,18,10,0.72) 30%, rgba(30,18,10,0.35) 60%, rgba(30,18,10,0.05) 100%);
}

/* Inner layout — left-anchored editorial */
.hero-v3-inner {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: 100%;
  padding: clamp(120px, 16vh, 180px) clamp(28px, 7vw, 110px) clamp(80px, 10vh, 120px);
}

/* Copy */
.hero-v3-copy {
  max-width: 640px;
  opacity: 0;
  animation: fadeUp 0.6s var(--ease-premium) forwards 0.15s;
}
.hero-v3-eyebrow {
  font-family: var(--sans);
  font-size: clamp(15px, 1.4vw, 20px);
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--blush);
  margin-bottom: 32px;
}
.hero-v3-title {
  font-family: var(--serif);
  font-size: clamp(60px, 8vw, 124px);
  font-weight: 400;
  line-height: 0.95;
  letter-spacing: -0.02em;
  color: var(--cream);
  margin-bottom: 24px;
}
.hero-v3-title-accent {
  color: var(--blush);
}
.hero-v3-sublead {
  font-family: var(--serif);
  font-style: italic;
  font-size: clamp(22px, 2.4vw, 34px);
  line-height: 1.25;
  color: var(--blush);
  margin: 0 0 28px;
}
.hero-v3-sub {
  font-family: var(--sans);
  font-size: clamp(15px, 1.15vw, 17px);
  line-height: 1.7;
  color: rgba(247,242,234,0.85);
  max-width: 480px;
  margin-bottom: 36px;
}
.hero-v3-trust {
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(247,242,234,0.6);
  margin-top: 22px;
}


/* CTA Button */
.hero-v3-cta {
  display: inline-block;
  padding: 20px 52px;
  background: var(--terracotta);
  color: var(--cream);
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: background 0.3s var(--ease-premium), transform 0.2s var(--ease-premium);
}
.hero-v3-cta:hover {
  background: var(--espresso);
}
.hero-v3-cta:active {
  transform: scale(0.98);
}

/* Sticky mobile ATC */
.hero-v3-sticky {
  display: none;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
  background: var(--cream);
  border-top: 1px solid var(--cream-dark);
  padding: 12px 20px;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  box-shadow: 0 -4px 20px rgba(30,18,10,0.08);
}
.hero-v3-sticky.visible { display: flex; }
.hero-v3-sticky-left {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.hero-v3-sticky-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--espresso);
}
.hero-v3-sticky-price {
  font-family: var(--serif);
  font-size: 16px;
  color: var(--espresso);
}
.hero-v3-sticky-btn {
  padding: 14px 28px;
  background: var(--terracotta);
  color: var(--cream);
  border: none;
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  text-decoration: none;
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;
}
.hero-v3-sticky-btn:hover { background: var(--espresso); }

/* ── Responsive ── */

/* Tablet — keep full-image overlay but flip overlay to top-down */
@media (max-width: 1024px) and (min-width: 881px) {
  .hero-v3 {
    min-height: 80svh;
  }
  .hero-v3-bg-overlay {
    background:
      linear-gradient(180deg, rgba(30,18,10,0.55) 0%, rgba(30,18,10,0.78) 60%, rgba(30,18,10,0.92) 100%);
  }
  .hero-v3-inner {
    padding: clamp(100px, 14vh, 140px) 32px clamp(56px, 8vh, 88px);
    justify-content: flex-start;
    align-items: flex-end;
  }
  .hero-v3-copy {
    max-width: none;
  }
  .hero-v3-title {
    font-size: clamp(56px, 9vw, 84px);
  }
  .hero-v3-sublead {
    font-size: clamp(22px, 3.4vw, 28px);
  }
}

/* Phone & small tablet — SPLIT LAYOUT: image up top, text below on solid */
@media (max-width: 880px) {
  .hero-v3 {
    min-height: 0;
    flex-direction: column;
  }
  .hero-v3-bg {
    position: relative;
    inset: auto;
    width: 100%;
    height: clamp(360px, 50vh, 460px);
    flex-shrink: 0;
  }
  .hero-v3-bg img {
    object-position: 50% 60%;
  }
  .hero-v3-bg-overlay {
    background: linear-gradient(180deg, rgba(30,18,10,0) 65%, rgba(30,18,10,0.35) 100%);
  }
  .hero-v3-inner {
    position: relative;
    z-index: 1;
    background: var(--espresso, #1E120A);
    padding: clamp(36px, 6vh, 56px) 24px clamp(40px, 6vh, 56px);
    align-items: flex-start;
    justify-content: flex-start;
    flex: 0 1 auto;
  }
  .hero-v3-copy {
    max-width: none;
    width: 100%;
  }
  .hero-v3-eyebrow {
    font-size: 13px;
    letter-spacing: 0.18em;
    margin-bottom: 22px;
  }
  .hero-v3-title {
    font-size: clamp(40px, 10vw, 60px);
    line-height: 1.0;
    margin-bottom: 18px;
  }
  .hero-v3-sublead {
    font-size: clamp(19px, 4.6vw, 24px);
    margin-bottom: 22px;
  }
  .hero-v3-sub {
    font-size: 15px;
    line-height: 1.65;
    margin-bottom: 28px;
  }
  .hero-v3-cta {
    padding: 16px 28px;
    width: 100%;
    max-width: none;
    text-align: center;
    font-size: 12px;
  }
  .hero-v3-trust {
    font-size: 10px;
    letter-spacing: 0.14em;
    margin-top: 18px;
  }
}
</style>

<script>
(function() {
  var cardBtn = document.querySelector('.hero-v3-cta');
  var stickyBar = document.getElementById('sticky-atc');
  if (!cardBtn || !stickyBar) return;

  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          stickyBar.classList.remove('visible');
        } else if (entry.boundingClientRect.bottom < 0) {
          stickyBar.classList.add('visible');
        }
      });
    }, { threshold: 0, rootMargin: '0px' });
    observer.observe(cardBtn);
  } else {
    var ticking = false;
    window.addEventListener('scroll', function() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function() {
        var rect = cardBtn.getBoundingClientRect();
        stickyBar.classList.toggle('visible', rect.bottom < 0);
        ticking = false;
      });
    }, { passive: true });
  }
})();
</script>

