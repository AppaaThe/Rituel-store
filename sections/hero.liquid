<section class="hero" id="home">
  <div class="hero-visual">
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | image_url: width: 800 }}" alt="RITUEL Gua Sha Set" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;">
    {%- else -%}
      <div class="hero-floating">
        <div class="hero-stone"></div>
        <div class="hero-roller"></div>
      </div>
    {%- endif -%}
  </div>
  <div class="hero-content">
    <p class="hero-eyebrow">{{ section.settings.eyebrow | default: 'The Morning Ritual' }}</p>
    <h1 class="hero-title">{{ section.settings.title | default: 'Sculpt.<br><em>Glow.</em><br>Repeat.' }}</h1>
    <p class="hero-subtitle">{{ section.settings.subtitle | default: 'A 5-minute ritual that transforms your skin from the inside out. Rose quartz gua sha meets ice therapy — the ancient ritual, perfected.' }}</p>

    <div class="bundle-selector">
      <a href="/products/rituel-starter-ritual" class="bundle-option active">
        <div class="bundle-radio"></div>
        <div class="bundle-info">
          <div class="bundle-name">Starter Ritual</div>
          <div class="bundle-includes">Gua Sha + Ice Roller</div>
        </div>
        <div class="bundle-price">&#8364;35 <span class="bundle-compare">&#8364;50</span></div>
      </a>
      <a href="/products/rituel-full-ritual" class="bundle-option">
        <div class="bundle-badge">Most Popular</div>
        <div class="bundle-radio"></div>
        <div class="bundle-info">
          <div class="bundle-name">Full Ritual</div>
          <div class="bundle-includes">Gua Sha + Jade Roller + Ice Roller</div>
        </div>
        <div class="bundle-price">&#8364;48 <span class="bundle-compare">&#8364;66</span></div>
      </a>
      <a href="/products/rituel-complete-ritual" class="bundle-option">
        <div class="bundle-radio"></div>
        <div class="bundle-info">
          <div class="bundle-name">Complete Ritual</div>
          <div class="bundle-includes">All 4 Products — Best Value</div>
        </div>
        <div class="bundle-price">&#8364;58 <span class="bundle-compare">&#8364;80</span></div>
      </a>
    </div>

    <a href="/products/rituel-starter-ritual" class="btn-primary" style="text-decoration:none;display:block;text-align:center;">
      <span>Start Your Ritual &#8364;35</span>
    </a>

    <div class="hero-trust">
      <div class="trust-item"><span class="trust-dot"></span> Free shipping over &#8364;45</div>
      <div class="trust-item"><span class="trust-dot"></span> 30-day guarantee</div>
      <div class="trust-item"><span class="trust-dot"></span> Natural amethyst stone</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "The Morning Ritual" },
    { "type": "textarea", "id": "title", "label": "Headline", "default": "Sculpt. Glow. Repeat." },
    { "type": "textarea", "id": "subtitle", "label": "Subheadline" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
