<!-- Sticky mobile ATC -->
<div class="hero-v3-sticky" id="sticky-atc">
  <div class="hero-v3-sticky-left">
    <span class="hero-v3-sticky-name">Amethyst Gua Sha</span>
    <span class="hero-v3-sticky-price">$22</span>
  </div>
  <a href="/products/rituel-gua-sha" class="hero-v3-sticky-btn" style="text-decoration:none;">Add to Cart</a>
</div>

<style>
/* ── HERO V3: Editorial Lifestyle + Floating Product Card ── */
.hero-v3 {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Background */
.hero-v3-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero-v3-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 15%;
}
.hero-v3-bg-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(135deg, rgba(30,18,10,0.82) 0%, rgba(30,18,10,0.55) 50%, rgba(30,18,10,0.3) 100%);
}

/* Inner layout */
.hero-v3-inner {
  position: relative;
  z-index: 1;
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 60px;
  align-items: center;
  max-width: 1300px;
  margin: 0 auto;
  padding: 140px 80px 100px;
  width: 100%;
}

/* Left copy */
.hero-v3-copy {
  opacity: 0;
  animation: fadeUp 0.8s ease forwards 0.2s;
}
.hero-v3-eyebrow {
  font-size: 10px;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--terracotta);
  margin-bottom: 24px;
}
.hero-v3-title {
  font-family: var(--serif);
  font-size: clamp(38px, 4.5vw, 64px);
  font-weight: 300;
  line-height: 1.08;
  color: var(--cream);
  margin-bottom: 24px;
}
.hero-v3-title em {
  font-style: italic;
  color: var(--blush);
}
.hero-v3-sub {
  font-size: 15px;
  line-height: 1.8;
  color: rgba(247,242,234,0.55);
  max-width: 440px;
  margin-bottom: 28px;
}
.hero-v3-proof {
  display: flex;
  align-items: center;
  gap: 12px;
}
.hero-v3-stars {
  color: var(--terracotta);
  font-size: 12px;
  letter-spacing: 2px;
}
.hero-v3-quote {
  font-family: var(--serif);
  font-size: 14px;
  font-style: italic;
  color: rgba(247,242,234,0.4);
}

/* Right product card */
.hero-v3-card {
  background: var(--cream);
  box-shadow: 0 24px 80px rgba(30,18,10,0.25), 0 4px 20px rgba(30,18,10,0.1);
  overflow: hidden;
  opacity: 0;
  animation: cardSlideIn 0.8s ease forwards 0.4s;
}
@keyframes cardSlideIn {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}
.hero-v3-card-img {
  background: #f5f0eb;
  padding: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.hero-v3-card-img img {
  width: 100%;
  max-height: 280px;
  object-fit: contain;
}
.hero-v3-card-body {
  padding: 28px 28px 24px;
}
.hero-v3-card-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16px;
}
.hero-v3-card-name {
  font-family: var(--serif);
  font-size: 22px;
  font-weight: 400;
  color: var(--espresso);
}
.hero-v3-card-price {
  font-family: var(--serif);
  font-size: 24px;
  color: var(--espresso);
}
.hero-v3-card-details {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 20px;
}
.hero-v3-card-details span {
  font-size: 12px;
  color: var(--stone);
  letter-spacing: 0.02em;
}
.hero-v3-card-btn {
  display: block;
  width: 100%;
  padding: 18px;
  background: var(--terracotta);
  color: var(--cream);
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-align: center;
  border: none;
  cursor: pointer;
  transition: background 0.3s;
  margin-bottom: 10px;
}
.hero-v3-card-btn:hover {
  background: var(--espresso);
}
.hero-v3-card-note {
  display: block;
  text-align: center;
  font-size: 11px;
  color: var(--stone);
  letter-spacing: 0.04em;
}

/* Bottom trust bar */
.hero-v3-trust-bar {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24px;
  padding: 18px 40px;
  background: rgba(30,18,10,0.6);
  backdrop-filter: blur(8px);
  border-top: 1px solid rgba(247,242,234,0.08);
}
.hero-v3-trust-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  letter-spacing: 0.06em;
  color: rgba(247,242,234,0.5);
}
.hero-v3-trust-item svg {
  color: var(--terracotta);
  flex-shrink: 0;
}
.hero-v3-trust-stars {
  color: var(--terracotta);
  font-size: 10px;
  letter-spacing: 1px;
}
.hero-v3-trust-sep {
  width: 1px;
  height: 14px;
  background: rgba(247,242,234,0.12);
}

/* Sticky mobile ATC */
.hero-v3-sticky {
  display: none;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
  background: var(--cream);
  border-top: 1px solid var(--cream-dark);
  padding: 12px 20px;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  box-shadow: 0 -4px 20px rgba(30,18,10,0.08);
}
.hero-v3-sticky.visible { display: flex; }
.hero-v3-sticky-left {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.hero-v3-sticky-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--espresso);
}
.hero-v3-sticky-price {
  font-family: var(--serif);
  font-size: 16px;
  color: var(--espresso);
}
.hero-v3-sticky-btn {
  padding: 14px 28px;
  background: var(--terracotta);
  color: var(--cream);
  border: none;
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;
}
.hero-v3-sticky-btn:hover { background: var(--espresso); }

/* ── Responsive ── */
@media (max-width: 1024px) {
  .hero-v3-inner {
    grid-template-columns: 1fr;
    padding: 120px 24px 40px;
    gap: 32px;
  }
  .hero-v3-title {
    font-size: 32px;
  }
  .hero-v3-card {
    max-width: 400px;
  }
  .hero-v3-trust-bar {
    flex-wrap: wrap;
    gap: 12px 20px;
    padding: 16px 24px;
  }
  .hero-v3-trust-sep {
    display: none;
  }
  .hero-v3-copy {
    padding-bottom: 0;
  }
  .hero-v3-card-body {
    padding-bottom: 100px;
  }
}
</style>

<script>
(function() {
  var cardBtn = document.querySelector('.hero-v3-card-btn');
  var stickyBar = document.getElementById('sticky-atc');
  if (!cardBtn || !stickyBar) return;

  function checkSticky() {
    var rect = cardBtn.getBoundingClientRect();
    if (rect.bottom < 0) {
      stickyBar.classList.add('visible');
    } else {
      stickyBar.classList.remove('visible');
    }
    requestAnimationFrame(checkSticky);
  }
  checkSticky();
})();
</script>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "The 5-Minute Morning Ritual" },
    { "type": "textarea", "id": "title", "label": "Headline", "default": "Sculpt your jawline. Depuff your face." },
    { "type": "textarea", "id": "subtitle", "label": "Subheadline" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
