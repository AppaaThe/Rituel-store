<section class="hero-v3" id="home">

  <!-- Full-width lifestyle background -->
  <div class="hero-v3-bg">
    <img
      src="{{ 'br-hero-guasha-faceclose.webp' | asset_url }}"
      alt="Close-up of an amethyst gua sha stone gliding along the jawline"
      width="2752"
      height="1536"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    >
    <div class="hero-v3-bg-overlay"></div>
  </div>

  <!-- Content layer -->
  <div class="hero-v3-inner hero-v3-inner--centered">

    <div class="hero-v3-copy hero-v3-copy--centered">
      <p class="hero-v3-eyebrow">Wake up puffy · tired · undefined</p>
      <h1 class="hero-v3-title">Five minutes. One stone.<br><span class="hero-v3-title-accent">A face that looks rested.</span></h1>
      <p class="hero-v3-sub">The amethyst gua sha is a hand-carved stone you sweep upward across your face every morning. It drains puffiness, sculpts your jawline, and releases the jaw tension you sleep with.</p>
      <a href="/products/amethyst-gua-sha" class="hero-v3-cta">Shop the Amethyst Gua Sha — $22</a>
      <p class="hero-v3-trust">Hand-carved real amethyst · 30-day guarantee</p>
    </div>

  </div>

</section>

<!-- Sticky mobile ATC -->
<div class="hero-v3-sticky" id="sticky-atc">
  <div class="hero-v3-sticky-left">
    <span class="hero-v3-sticky-name">Amethyst Gua Sha</span>
    <span class="hero-v3-sticky-price">$22</span>
  </div>
  <a href="/products/amethyst-gua-sha" class="hero-v3-sticky-btn">Shop Now</a>
</div>

<style>
/* ── HERO V3: Editorial Lifestyle + Floating Product Card ── */
.hero-v3 {
  position: relative;
  min-height: 85vh;
  display: flex;
  flex-direction: column;
}

/* Background */
.hero-v3-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero-v3-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: 60% 55%;
}
.hero-v3-bg-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(105deg, rgba(30,18,10,0.78) 0%, rgba(30,18,10,0.5) 45%, rgba(30,18,10,0.15) 100%);
}

/* Inner layout */
/* Centered layout */
.hero-v3-inner {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  max-width: 1300px;
  margin: 0 auto;
  padding: 140px 80px 100px;
  width: 100%;
}

/* Copy */
.hero-v3-copy {
  opacity: 0;
  animation: fadeUp 0.5s var(--ease-premium) forwards 0.15s;
}
.hero-v3-eyebrow {
  font-size: 10px;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--terracotta);
  margin-bottom: 24px;
}
.hero-v3-title {
  font-family: var(--serif);
  font-size: clamp(44px, 5.2vw, 76px);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.01em;
  color: var(--cream);
  margin-bottom: 28px;
}
.hero-v3-title-accent {
  color: var(--blush);
}
.hero-v3-sub {
  font-size: 15px;
  line-height: 1.7;
  color: rgba(247,242,234,0.72);
  max-width: 420px;
  margin-bottom: 32px;
}
.hero-v3-trust {
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(247,242,234,0.55);
  margin-top: 20px;
}

/* CTA Button */
.hero-v3-cta {
  display: inline-block;
  padding: 20px 52px;
  background: var(--terracotta);
  color: var(--cream);
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: background 0.3s var(--ease-premium), transform 0.2s var(--ease-premium);
}
.hero-v3-cta:hover {
  background: var(--espresso);
}
.hero-v3-cta:active {
  transform: scale(0.98);
}

/* Sticky mobile ATC */
.hero-v3-sticky {
  display: none;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
  background: var(--cream);
  border-top: 1px solid var(--cream-dark);
  padding: 12px 20px;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  box-shadow: 0 -4px 20px rgba(30,18,10,0.08);
}
.hero-v3-sticky.visible { display: flex; }
.hero-v3-sticky-left {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.hero-v3-sticky-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--espresso);
}
.hero-v3-sticky-price {
  font-family: var(--serif);
  font-size: 16px;
  color: var(--espresso);
}
.hero-v3-sticky-btn {
  padding: 14px 28px;
  background: var(--terracotta);
  color: var(--cream);
  border: none;
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  text-decoration: none;
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;
}
.hero-v3-sticky-btn:hover { background: var(--espresso); }

/* ── Responsive ── */
@media (max-width: 1024px) {
  .hero-v3 {
    min-height: 85svh;
  }
  .hero-v3-inner {
    padding: 96px 24px 48px;
    justify-content: center;
    text-align: center;
  }
  .hero-v3-sub {
    margin-left: auto;
    margin-right: auto;
  }
}
@media (max-width: 540px) {
  .hero-v3-cta {
    padding: 18px 40px;
    width: 100%;
    max-width: 320px;
  }
}
</style>

<script>
(function() {
  var cardBtn = document.querySelector('.hero-v3-cta');
  var stickyBar = document.getElementById('sticky-atc');
  if (!cardBtn || !stickyBar) return;

  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          stickyBar.classList.remove('visible');
        } else if (entry.boundingClientRect.bottom < 0) {
          stickyBar.classList.add('visible');
        }
      });
    }, { threshold: 0, rootMargin: '0px' });
    observer.observe(cardBtn);
  } else {
    var ticking = false;
    window.addEventListener('scroll', function() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function() {
        var rect = cardBtn.getBoundingClientRect();
        stickyBar.classList.toggle('visible', rect.bottom < 0);
        ticking = false;
      });
    }, { passive: true });
  }
})();
</script>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "The 5-Minute Morning Ritual" },
    { "type": "textarea", "id": "title", "label": "Headline", "default": "Sculpt your jawline. Depuff your face." },
    { "type": "textarea", "id": "subtitle", "label": "Subheadline" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
