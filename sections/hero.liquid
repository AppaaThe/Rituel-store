<style>
/* ── HERO V2: Product-First Buy-Now ── */
.hero-v2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 100vh;
  padding-top: 80px;
}

/* LEFT — Product image */
.hero-v2-visual {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--cream-dark);
  overflow: hidden;
}
.hero-v2-img-wrap {
  padding: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}
.hero-v2-product {
  max-width: 85%;
  max-height: 75vh;
  object-fit: contain;
  opacity: 0;
  animation: heroProductIn 0.8s ease forwards 0.2s;
}
@keyframes heroProductIn {
  from { opacity: 0; transform: scale(0.96) translateY(12px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}
.hero-v2-img-badge {
  position: absolute;
  bottom: 28px;
  left: 28px;
  font-size: 12px;
  letter-spacing: 0.05em;
  color: var(--stone);
  background: var(--white);
  padding: 8px 16px;
  border-radius: 2px;
  box-shadow: 0 2px 12px rgba(30,18,10,0.08);
}
.hero-v2-img-badge span {
  color: var(--terracotta);
  font-weight: 600;
}

/* RIGHT — Content + Buy */
.hero-v2-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80px 64px 80px 56px;
  max-width: 620px;
}

.hero-v2-eyebrow {
  font-size: 10px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--terracotta);
  margin-bottom: 20px;
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.1s;
}

.hero-v2-title {
  font-family: var(--serif);
  font-size: clamp(30px, 3.2vw, 46px);
  line-height: 1.15;
  font-weight: 300;
  color: var(--espresso);
  margin-bottom: 20px;
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.2s;
}
.hero-v2-title em {
  font-style: italic;
  color: var(--terracotta);
}

.hero-v2-sub {
  font-size: 14px;
  line-height: 1.75;
  color: var(--stone);
  margin-bottom: 20px;
  max-width: 420px;
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.3s;
}

.hero-v2-social-proof {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 28px;
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.35s;
}
.hero-v2-stars {
  color: var(--terracotta);
  font-size: 13px;
  letter-spacing: 2px;
  flex-shrink: 0;
}
.hero-v2-review-count {
  font-family: var(--serif);
  font-size: 13px;
  font-style: italic;
  color: var(--stone);
  line-height: 1.4;
}

/* Price row */
.hero-v2-price-row {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 20px;
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.4s;
}
.hero-v2-price {
  font-family: var(--serif);
  font-size: 36px;
  color: var(--espresso);
  font-weight: 400;
}
/* What's included */
.hero-v2-includes {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 24px;
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.45s;
}
.hero-v2-includes-item {
  font-size: 13px;
  color: var(--stone);
  letter-spacing: 0.02em;
}

/* CTA Button */
.hero-v2-atc {
  width: 100%;
  padding: 20px 48px;
  background: var(--terracotta);
  color: var(--cream);
  border: none;
  font-family: var(--sans);
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.3s;
  margin-bottom: 10px;
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.5s;
}
.hero-v2-atc:hover {
  background: var(--espresso);
}

.hero-v2-shipping-note {
  font-size: 11px;
  color: var(--stone);
  text-align: center;
  letter-spacing: 0.05em;
  margin-bottom: 28px;
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.55s;
}

/* Trust strip */
.hero-v2-trust {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.6s ease forwards 0.6s;
}
.hero-v2-trust-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: var(--stone);
  letter-spacing: 0.03em;
}
.hero-v2-trust-item svg {
  color: var(--terracotta);
  flex-shrink: 0;
}

/* ── Sticky Mobile ATC ── */
.hero-v2-sticky-atc {
  display: none;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
  background: var(--cream);
  border-top: 1px solid var(--cream-dark);
  padding: 12px 20px;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  box-shadow: 0 -4px 20px rgba(30,18,10,0.08);
}
.hero-v2-sticky-atc.visible {
  display: flex;
}
.sticky-atc-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.sticky-atc-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--espresso);
}
.sticky-atc-price {
  font-family: var(--serif);
  font-size: 16px;
  color: var(--espresso);
}
.sticky-atc-price s {
  font-size: 12px;
  color: var(--stone);
  margin-left: 4px;
}
.sticky-atc-btn {
  padding: 14px 28px;
  background: var(--terracotta);
  color: var(--cream);
  border: none;
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;
}
.sticky-atc-btn:hover {
  background: var(--espresso);
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .hero-v2 {
    grid-template-columns: 1fr;
    padding-top: 72px;
  }
  .hero-v2-visual {
    height: 50vh;
    min-height: 320px;
  }
  .hero-v2-content {
    padding: 40px 28px 120px;
    max-width: 100%;
  }
  .hero-v2-title {
    font-size: 28px;
  }
  .hero-v2-trust {
    flex-direction: column;
    gap: 10px;
  }
}
</style>

<script>
(function() {
  var heroAtc = document.querySelector('.hero-v2-atc');
  var stickyBar = document.getElementById('sticky-atc');
  if (!heroAtc || !stickyBar) return;

  // Sticky ATC — show when hero CTA scrolls out of view
  function checkSticky() {
    var rect = heroAtc.getBoundingClientRect();
    if (rect.bottom < 0) {
      stickyBar.classList.add('visible');
    } else {
      stickyBar.classList.remove('visible');
    }
    requestAnimationFrame(checkSticky);
  }
  checkSticky();
})();
</script>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "The 5-Minute Morning Ritual" },
    { "type": "textarea", "id": "title", "label": "Headline", "default": "Sculpt your jawline. Depuff your face. Look like you slept 10 hours." },
    { "type": "textarea", "id": "subtitle", "label": "Subheadline" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
