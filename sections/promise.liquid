<section class="promise-section" id="promise">

  <div class="promise-image reveal">
    <img
      src="{{ 'br-guasha-closeup.webp' | asset_url }}"
      alt="Close-up of an amethyst gua sha stone being used along the jawline"
      loading="lazy"
    >
    <div class="promise-image-overlay" aria-hidden="true"></div>
    <div class="promise-image-text">
      <span class="promise-image-label">The Ritual</span>
      <h2 class="promise-image-title">Real results.<br><span class="promise-image-title-accent">Real commitment.</span></h2>
      <p class="promise-image-sub">Five minutes every morning. That&rsquo;s the only secret.</p>
    </div>
  </div>

  <div class="promise-cards">
    <div class="promise-cards-inner">

      <article class="promise-card reveal">
        <span class="promise-card-num" aria-hidden="true">01</span>
        <div class="promise-card-body">
          <h3>Visible from day one</h3>
          <p>Gua sha physically moves fluid and boosts microcirculation. You&rsquo;ll see less puffiness after the very first session.</p>
        </div>
      </article>

      <article class="promise-card reveal reveal-delay-1">
        <span class="promise-card-num" aria-hidden="true">02</span>
        <div class="promise-card-body">
          <h3>Better with consistency</h3>
          <p>Like any ritual, results compound. By week two or three, the difference becomes something other people notice.</p>
        </div>
      </article>

      <article class="promise-card reveal reveal-delay-2">
        <span class="promise-card-num" aria-hidden="true">03</span>
        <div class="promise-card-body">
          <h3>Backed by our guarantee</h3>
          <p>Try it for thirty days. If you don&rsquo;t see a difference, we refund every penny. No questions, no hassle.</p>
        </div>
      </article>

    </div>
  </div>

</section>

<style>
  .promise-section {
    background: var(--cream, #F7F2EA);
  }

  .promise-image {
    position: relative;
    height: 45vh;
    min-height: 320px;
    max-height: 440px;
    overflow: hidden;
  }
  .promise-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 35% center;
    display: block;
  }
  .promise-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(30, 18, 10, 0.25) 0%, rgba(30, 18, 10, 0.78) 100%);
  }
  .promise-image-text {
    position: absolute;
    bottom: 56px;
    left: 80px;
    right: 80px;
    z-index: 1;
    max-width: 640px;
  }
  .promise-image-label {
    display: inline-block;
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--blush, #E8C5B0);
    margin-bottom: 18px;
  }
  .promise-image-title {
    font-family: var(--serif), Georgia, serif;
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 400;
    color: var(--cream, #F7F2EA);
    line-height: 1.1;
    margin: 0 0 14px;
  }
  .promise-image-title-accent {
    color: var(--blush, #E8C5B0);
  }
  .promise-image-sub {
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: rgba(247, 242, 234, 0.82);
    letter-spacing: 0.01em;
    margin: 0;
    max-width: 46ch;
  }

  .promise-cards {
    background: var(--cream, #F7F2EA);
    padding: 80px 80px;
  }
  .promise-cards-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--cream-dark, #EDE6D6);
  }
  .promise-card {
    display: flex;
    gap: 22px;
    padding: 40px 32px;
    background: var(--cream, #F7F2EA);
  }
  .promise-card-num {
    font-family: var(--serif), Georgia, serif;
    font-size: 40px;
    color: var(--terracotta, #B8704A);
    opacity: 0.7;
    line-height: 1;
    flex-shrink: 0;
  }
  .promise-card-body h3 {
    font-family: var(--serif), Georgia, serif;
    font-size: 19px;
    font-weight: 400;
    color: var(--espresso, #1E120A);
    margin: 0 0 10px;
    line-height: 1.3;
  }
  .promise-card-body p {
    font-family: var(--sans), system-ui, sans-serif;
    font-size: 13px;
    line-height: 1.75;
    color: #6E5A42;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .promise-image-text {
      left: 32px;
      right: 32px;
      bottom: 40px;
    }
    .promise-cards {
      padding: 56px 32px;
    }
    .promise-cards-inner {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 600px) {
    .promise-image {
      height: 50vh;
      min-height: 320px;
    }
    .promise-image-text {
      left: 20px;
      right: 20px;
      bottom: 28px;
    }
    .promise-cards {
      padding: 40px 16px;
    }
    .promise-card {
      padding: 28px 20px;
    }
  }
</style>

{% schema %}
{
  "name": "Promise",
  "presets": [{ "name": "Promise" }]
}
{% endschema %}
