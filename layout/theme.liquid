<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="google-site-verification" content="h-pSpvoGVv1r0pxHxFF8GJAq13jhVU_l14xbUVMD42Q" />
  <meta name="facebook-domain-verification" content="lp7xnm2tcmulo0b9e4v8py5ogtes7s" />
  <meta name="theme-color" content="{{ settings.color_background }}">
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://api.fontshare.com">
  <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Gloock&display=swap">
  <link rel="preload" as="style" href="https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,700&display=swap">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Gloock&display=swap" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,700&display=swap" media="print" onload="this.media='all'">
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Gloock&display=swap">
    <link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,700&display=swap">
  </noscript>

  {%- comment -%} Favicons — hardcoded to the actual BY RITUEL logo (rituel-logo-optimized.png). Falls back to settings.favicon only if the asset is somehow missing. {%- endcomment -%}
  <link rel="icon" type="image/png" sizes="32x32" href="{{ 'rituel-logo-optimized.png' | asset_url }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ 'rituel-logo-optimized.png' | asset_url }}">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ 'rituel-logo-optimized.png' | asset_url }}">
  <link rel="shortcut icon" href="{{ 'rituel-logo-optimized.png' | asset_url }}" type="image/png">
  {%- if settings.favicon != blank -%}
    <link rel="mask-icon" href="{{ settings.favicon | image_url: width: 32, height: 32 }}" color="#c7744a">
  {%- endif -%}

  <title>{{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {%- liquid
    assign og_title = page_title | default: shop.name
    assign shop_homepage_meta = shop.metafields.custom.homepage_description | default: shop.description | default: shop.name
    assign og_description = page_description | default: shop_homepage_meta
    if template contains 'product' and product
      assign og_type = 'product'
      assign og_image = product.featured_image | image_url: width: 1200
    elsif template contains 'article' and article
      assign og_type = 'article'
      assign og_image = article.image | image_url: width: 1200
    else
      assign og_type = 'website'
      assign og_image = settings.share_image | image_url: width: 1200
    endif
  -%}
  <meta property="og:type" content="{{ og_type }}">
  <meta property="og:title" content="{{ og_title | escape }}">
  <meta property="og:description" content="{{ og_description | escape }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:site_name" content="{{ shop.name | escape }}">
  {%- if og_image != blank -%}
    <meta property="og:image" content="{{ og_image }}">
    <meta property="og:image:width" content="1200">
  {%- endif -%}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ og_title | escape }}">
  <meta name="twitter:description" content="{{ og_description | escape }}">
  {%- if og_image != blank -%}
    <meta name="twitter:image" content="{{ og_image }}">
  {%- endif -%}

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "{{ shop.name }}",
    "url": "{{ shop.url }}",
    "logo": "{% if settings.logo %}{{ settings.logo | image_url: width: 600 }}{% else %}{{ shop.url }}{% endif %}",
    "description": "{{ shop.description | default: 'The 5-minute morning ritual. Amethyst gua sha, ice rollers, and facial tools.' | escape }}"
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ shop.name }}",
    "url": "{{ shop.url }}",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ shop.url }}/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  {{ content_for_header }}

  {{ 'base.css' | asset_url | stylesheet_tag }}

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-547FPGHNXW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-547FPGHNXW', {
      'send_page_view': true,
      {%- if customer %}
      'user_id': '{{ customer.id }}',
      {%- endif %}
      'page_location': window.location.href,
      'page_title': document.title
    });
    {%- if template contains 'product' and product %}
    gtag('event', 'view_item', {
      currency: '{{ cart.currency.iso_code }}',
      value: {{ product.selected_or_first_available_variant.price | money_without_currency | replace: ',', '.' }},
      items: [{
        item_id: '{{ product.id }}',
        item_name: {{ product.title | json }},
        item_brand: {{ product.vendor | json }},
        price: {{ product.selected_or_first_available_variant.price | money_without_currency | replace: ',', '.' }}
      }]
    });
    {%- endif %}
    {%- if template contains 'collection' and collection %}
    gtag('event', 'view_item_list', {
      item_list_id: '{{ collection.handle }}',
      item_list_name: {{ collection.title | json }}
    });
    {%- endif %}

    // ── add_to_cart (intercepts every Shopify cart/add — AJAX + form submit) ──
    (function () {
      var origFetch = window.fetch;
      window.fetch = function () {
        var args = arguments;
        var url = args[0];
        var urlStr = (typeof url === 'string') ? url : (url && url.url) || '';
        var isAdd = urlStr.indexOf('/cart/add') !== -1;
        var p = origFetch.apply(this, args);
        if (isAdd) {
          p.then(function (r) { return r.clone().json().catch(function () { return null; }); })
           .then(function (data) {
             if (!data) return;
             var items = (data.items || [data]).map(function (it) {
               return {
                 item_id: String(it.product_id || it.id || ''),
                 item_name: it.product_title || it.title || '',
                 item_variant: it.variant_title || '',
                 price: (it.price || 0) / 100,
                 quantity: it.quantity || 1
               };
             });
             var value = items.reduce(function (s, i) { return s + (i.price * i.quantity); }, 0);
             gtag('event', 'add_to_cart', { currency: '{{ cart.currency.iso_code }}', value: value, items: items });
           }).catch(function () {});
        }
        return p;
      };

      // Fallback: traditional form-submit add-to-cart (non-AJAX themes)
      document.addEventListener('submit', function (e) {
        var form = e.target;
        if (form && form.action && form.action.indexOf('/cart/add') !== -1) {
          var qty = parseInt((form.querySelector('[name="quantity"]') || {}).value || 1, 10);
          gtag('event', 'add_to_cart', {
            currency: '{{ cart.currency.iso_code }}',
            items: [{ item_id: (form.querySelector('[name="id"]') || {}).value || '', quantity: qty }]
          });
        }
      }, true);
    })();

    // ── begin_checkout (fires when user navigates to /checkout) ──
    document.addEventListener('click', function (e) {
      var t = e.target.closest && e.target.closest('a, button, input[type="submit"]');
      if (!t) return;
      var href = t.getAttribute && (t.getAttribute('href') || '');
      var name = (t.getAttribute && t.getAttribute('name')) || '';
      var goesToCheckout = href.indexOf('/checkout') !== -1 || name === 'checkout';
      if (goesToCheckout) {
        // Pull current cart for items + value (best-effort, non-blocking)
        fetch('/cart.js').then(function (r) { return r.json(); }).then(function (cart) {
          var items = (cart.items || []).map(function (it) {
            return {
              item_id: String(it.product_id || ''),
              item_name: it.product_title || it.title || '',
              item_variant: it.variant_title || '',
              price: (it.price || 0) / 100,
              quantity: it.quantity || 1
            };
          });
          gtag('event', 'begin_checkout', {
            currency: cart.currency || '{{ cart.currency.iso_code }}',
            value: (cart.total_price || 0) / 100,
            items: items
          });
        }).catch(function () {
          gtag('event', 'begin_checkout', { currency: '{{ cart.currency.iso_code }}' });
        });
      }
    }, true);
  </script>
  <!-- /Google Analytics 4 -->
</head>

<body class="template-{{ template.name }}">
  <a class="skip-to-content" href="#MainContent">Skip to content</a>
  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  {% section 'header' %}

  <main id="MainContent" class="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {%- if template.name == 'index' -%}
    {% render 'sticky-cta' %}
  {%- endif -%}
  {%- comment -%}
    Custom exit-intent popup removed 2026-04-19 — Klaviyo client API call was missing
    company_id query param, so subscribes silently failed. Klaviyo-dashboard popup
    remains as the single working email capture. File kept at sections/email-popup.liquid
    for future re-enable after fixing the API URL.
  {%- endcomment -%}

  <script src="{{ 'rituel.js' | asset_url }}" defer></script>

  <!-- Klaviyo onsite tracking (works with Shopify Klaviyo app) -->
  <script>
    // Klaviyo identify on page load if customer is logged in
    {% if customer %}
      window._learnq = window._learnq || [];
      window._learnq.push(['identify', {
        '$email': '{{ customer.email }}',
        '$first_name': '{{ customer.first_name }}',
        '$last_name': '{{ customer.last_name }}'
      }]);
    {% endif %}
  </script>

  <!-- AI Chatbot — paste embed script here once you pick a provider (Chatbase, Tidio, etc.) -->
</body>
</html>
