<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_background }}">
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap"></noscript>

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>{{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {%- liquid
    assign og_title = page_title | default: shop.name
    assign og_description = page_description | default: shop.description | default: shop.name
    if template contains 'product' and product
      assign og_type = 'product'
      assign og_image = product.featured_image | image_url: width: 1200
    elsif template contains 'article' and article
      assign og_type = 'article'
      assign og_image = article.image | image_url: width: 1200
    else
      assign og_type = 'website'
      assign og_image = settings.share_image | image_url: width: 1200
    endif
  -%}
  <meta property="og:type" content="{{ og_type }}">
  <meta property="og:title" content="{{ og_title | escape }}">
  <meta property="og:description" content="{{ og_description | escape }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:site_name" content="{{ shop.name | escape }}">
  {%- if og_image != blank -%}
    <meta property="og:image" content="{{ og_image }}">
    <meta property="og:image:width" content="1200">
  {%- endif -%}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ og_title | escape }}">
  <meta name="twitter:description" content="{{ og_description | escape }}">
  {%- if og_image != blank -%}
    <meta name="twitter:image" content="{{ og_image }}">
  {%- endif -%}

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "{{ shop.name }}",
    "url": "{{ shop.url }}",
    "logo": "{% if settings.logo %}{{ settings.logo | image_url: width: 600 }}{% else %}{{ shop.url }}{% endif %}",
    "description": "{{ shop.description | default: 'The 5-minute morning ritual. Amethyst gua sha, ice rollers, and facial tools.' | escape }}"
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ shop.name }}",
    "url": "{{ shop.url }}",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ shop.url }}/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  {{ content_for_header }}

  {{ 'base.css' | asset_url | stylesheet_tag }}
</head>

<body class="template-{{ template.name }}">
  <a class="skip-to-content" href="#MainContent">Skip to content</a>
  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  {% section 'header' %}

  <main id="MainContent" class="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <script src="{{ 'rituel.js' | asset_url }}" defer></script>

  <!-- Klaviyo onsite tracking (works with Shopify Klaviyo app) -->
  <script>
    // Klaviyo identify on page load if customer is logged in
    {% if customer %}
      window._learnq = window._learnq || [];
      window._learnq.push(['identify', {
        '$email': '{{ customer.email }}',
        '$first_name': '{{ customer.first_name }}',
        '$last_name': '{{ customer.last_name }}'
      }]);
    {% endif %}
  </script>

  <!-- Native Floating Chat — opens DMs directly on user's phone -->
  <div class="rituel-chat" id="rituelChat">
    <button class="rituel-chat-bubble" id="rituelChatBubble" aria-label="Chat with us">
      <svg class="chat-icon-msg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      <svg class="chat-icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="rituel-chat-panel" id="rituelChatPanel">
      <div class="rituel-chat-header">
        <p class="rituel-chat-eyebrow">Hi there</p>
        <h4>Chat with the BY RITUEL team</h4>
        <p class="rituel-chat-sub">We usually reply within 1 hour.</p>
      </div>
      <div class="rituel-chat-options">
        <a href="https://m.me/byrituel" target="_blank" rel="noopener" class="rituel-chat-option">
          <span class="option-icon" style="background:#0084FF;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M12 2C6.5 2 2 6.14 2 11.25c0 2.88 1.45 5.46 3.73 7.16V22l3.41-1.87c.91.25 1.87.38 2.86.38 5.5 0 10-4.14 10-9.25S17.5 2 12 2zm1 12.44l-2.55-2.71L5.5 14.44l5.48-5.81 2.6 2.71 4.87-2.71-5.45 5.81z"/></svg>
          </span>
          <div>
            <strong>Messenger</strong>
            <span>Fastest reply</span>
          </div>
        </a>
        <a href="https://instagram.com/byrituel" target="_blank" rel="noopener" class="rituel-chat-option">
          <span class="option-icon" style="background:linear-gradient(45deg,#F58529,#DD2A7B,#8134AF);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </span>
          <div>
            <strong>Instagram DM</strong>
            <span>@byrituel</span>
          </div>
        </a>
        <a href="mailto:hello@byrituel.com" class="rituel-chat-option">
          <span class="option-icon" style="background:#2C1810;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <div>
            <strong>Email</strong>
            <span>hello@byrituel.com</span>
          </div>
        </a>
      </div>
      <div class="rituel-chat-footer">
        <p>Or check our <a href="/pages/faq">FAQ</a> for instant answers.</p>
      </div>
    </div>
  </div>

  <style>
    .rituel-chat {
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 999;
    }

    .rituel-chat-bubble {
      width: 58px;
      height: 58px;
      border-radius: 50%;
      background: #2C1810;
      color: #FAF6F0;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 28px rgba(30,18,10,0.25);
      transition: transform 0.25s ease, background 0.3s ease;
    }

    .rituel-chat-bubble:hover {
      transform: scale(1.08);
      background: #B8704A;
    }

    .rituel-chat-bubble .chat-icon-close { display: none; }
    .rituel-chat.open .rituel-chat-bubble .chat-icon-msg { display: none; }
    .rituel-chat.open .rituel-chat-bubble .chat-icon-close { display: block; }

    .rituel-chat-panel {
      position: absolute;
      bottom: 72px;
      right: 0;
      width: 320px;
      background: #FAF6F0;
      border: 1px solid rgba(30,18,10,0.08);
      box-shadow: 0 20px 60px rgba(30,18,10,0.18);
      opacity: 0;
      transform: translateY(12px) scale(0.96);
      pointer-events: none;
      transform-origin: bottom right;
      transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .rituel-chat.open .rituel-chat-panel {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: all;
    }

    .rituel-chat-header {
      background: #2C1810;
      color: #FAF6F0;
      padding: 24px 22px 20px;
    }

    .rituel-chat-eyebrow {
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #B8704A;
      margin: 0 0 6px;
    }

    .rituel-chat-header h4 {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 22px;
      font-weight: 400;
      margin: 0 0 4px;
      line-height: 1.2;
    }

    .rituel-chat-sub {
      font-size: 12px;
      color: rgba(250,246,240,0.55);
      margin: 0;
    }

    .rituel-chat-options {
      padding: 16px 16px 8px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .rituel-chat-option {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 14px;
      text-decoration: none;
      color: #1E120A;
      background: transparent;
      transition: background 0.2s;
    }

    .rituel-chat-option:hover {
      background: rgba(184,112,74,0.08);
    }

    .option-icon {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .rituel-chat-option strong {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #1E120A;
    }

    .rituel-chat-option span {
      font-size: 11px;
      color: #8B7355;
      letter-spacing: 0.02em;
    }

    .rituel-chat-footer {
      padding: 14px 22px 18px;
      border-top: 1px solid rgba(30,18,10,0.06);
      text-align: center;
    }

    .rituel-chat-footer p {
      font-size: 11px;
      color: #8B7355;
      margin: 0;
    }

    .rituel-chat-footer a {
      color: #B8704A;
      text-decoration: none;
      font-weight: 600;
    }

    @media (max-width: 600px) {
      .rituel-chat { bottom: 16px; right: 16px; }
      .rituel-chat-panel { width: calc(100vw - 32px); right: -8px; }
    }
  </style>

  <script>
    (function() {
      var chat = document.getElementById('rituelChat');
      var bubble = document.getElementById('rituelChatBubble');
      if (!chat || !bubble) return;
      bubble.addEventListener('click', function() {
        chat.classList.toggle('open');
      });
      document.addEventListener('click', function(e) {
        if (!chat.contains(e.target)) chat.classList.remove('open');
      });
    })();
  </script>
</body>
</html>
